---
import BaseLayout from "../layouts/BaseLayout.astro";
import LiftButton from "../components/LiftButton.astro";
---

<BaseLayout
  title="NOPE 404"
  description="That page isn't here."
  mainClass="site-main--viewport-floor"
>
  <section class="error-404">
    <div class="error-404__shell layout-shell">
      <div class="error-404__grid layout-grid">
        <div class="error-404__copy">
          <div class="error-404__intro">
            <h1 class="error-404__title">nope 404</h1>
          </div>
          <p class="error-404__summary">Wrong page. Right website.</p>
          <nav class="error-404__actions" aria-label="404 actions">
            <LiftButton href="/" variant="primary" experimentalTextColor={true}>
              Go home
            </LiftButton>
            <LiftButton href="/work" variant="secondary">See work</LiftButton>
          </nav>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-404 {
    flex: 1;
    min-width: 0;
    display: flex;
    min-height: 100%;
  }

  .error-404__shell {
    flex: 1;
    min-width: 0;
  }

  .error-404__grid {
    min-height: 100%;
    align-items: center;
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
  }

  .error-404__copy {
    grid-column: 3 / 9;
    display: flex;
    flex-direction: column;
    max-width: 34rem;
  }

  .error-404__intro {
    display: flex;
    flex-direction: column;
    padding-bottom: 8px;
  }

  .error-404__title {
    margin: 0;
    font-size: clamp(3.5rem, 12vw, 7rem);
    line-height: 0.95;
    text-transform: lowercase;
    text-wrap: balance;
  }

  .error-404__summary {
    margin: 0;
    padding-top: 24px;
    padding-bottom: 8px;
    max-width: 24ch;
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  .error-404__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    padding-top: 24px;
  }

  @media (max-width: 768px) {
    .error-404__grid {
      align-items: start;
    }

    .error-404__copy {
      grid-column: 1 / -1;
      padding-top: var(--space-12);
    }

    .error-404__summary {
      padding-top: 20px;
      font-size: var(--font-size-base);
    }

    .error-404__actions {
      padding-top: 20px;
    }
  }
</style>
