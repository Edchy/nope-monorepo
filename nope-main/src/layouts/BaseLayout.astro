---
import { Font } from "astro:assets";
import { ClientRouter, slide } from "astro:transitions";

import Header from "../components/Header.astro";
import DebugScrollOverlay from "@nope/ui/src/DebugScrollOverlay.astro";
import Footer from "@nope/ui/src/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  mainClass?: string;
}

import { SITE_TITLE } from "../config";
const { title, description = SITE_TITLE, mainClass } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <script is:inline>
      const syncMobileTransitionMode = () => {
        const isMobile = window.matchMedia("(max-width: 768px)").matches;
        const enabledMeta = document.querySelector(
          'meta[name="astro-view-transitions-enabled"]',
        );
        const fallbackMeta = document.querySelector(
          'meta[name="astro-view-transitions-fallback"]',
        );

        if (isMobile) {
          enabledMeta?.remove();
          fallbackMeta?.remove();
          return;
        }

        if (!enabledMeta) {
          const meta = document.createElement("meta");
          meta.name = "astro-view-transitions-enabled";
          meta.content = "true";
          document.head.append(meta);
        }

        if (!fallbackMeta) {
          const meta = document.createElement("meta");
          meta.name = "astro-view-transitions-fallback";
          meta.content = "animate";
          document.head.append(meta);
        }
      };

      syncMobileTransitionMode();
      document.addEventListener("astro:page-load", syncMobileTransitionMode);
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-zt-nature" />
  </head>
  <body>
    <Header
      siteTitle={SITE_TITLE}
      navLinks={[
        { href: "/work", label: "Work" },
        { href: "/about", label: "About" },
        { href: "https://blog.nope.digital", label: "Blog", isExternal: true },
      ]}
    />
    <main class:list={["site-main", mainClass]}>
      <div
        class="site-main__stage"
        transition:name="page-stage"
        transition:animate={slide({
          duration: "var(--motion-duration-page-transition)",
        })}
      >
        <slot />
      </div>
    </main>
    <DebugScrollOverlay />
    <Footer siteTitle={SITE_TITLE} />
  </body>
</html>

<style>
  .site-main {
    flex: 1;
    min-height: 0;
    display: flex;
  }

  .site-main.site-main--viewport-floor {
    min-height: 100vh;
    min-height: 100dvh;
  }

  @media (max-width: 768px) {
    .site-main.site-main--viewport-floor {
      min-height: 0;
    }
  }
</style>
