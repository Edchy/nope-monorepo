---
import { Font } from "astro:assets";
import { ClientRouter, slide } from "astro:transitions";

import Header from "../components/Header.astro";
import Footer from "@nope/ui/src/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

import { SITE_TITLE } from "../config";
const { title, description = SITE_TITLE } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-zt-nature" />
  </head>
  <body>
    <Header
      siteTitle={SITE_TITLE}
      navLinks={[
        { href: "/work", label: "Work" },
        { href: "/about", label: "About" },
        { href: "https://blog.nope.digital", label: "Blog", isExternal: true },
      ]}
    />
    <main class="site-main">
      <div
        class="site-main__stage"
        transition:name="page-stage"
        transition:animate={slide({
          duration: "var(--motion-duration-page-transition)",
        })}
      >
        <slot />
      </div>
    </main>
    <Footer siteTitle={SITE_TITLE} />
  </body>
</html>

<style>
  .site-main {
    flex: 1;
    min-height: 0;
    display: flex;
  }
</style>
