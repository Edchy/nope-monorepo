---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface NoteEntry extends CollectionEntry<"notes"> {
  Content: ReturnType<typeof render> extends Promise<infer R> ? R extends { Content: infer C } ? C : never : never;
  popoverId: string;
}

const notes: NoteEntry[] = await Promise.all(
  (await getCollection("notes", ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map(async (note) => {
      const { Content } = await render(note);
      const popoverId = `note-${note.id.replace(/[^a-z0-9]/gi, "-")}`;
      return { ...note, Content, popoverId } as NoteEntry;
    })
);

const links = (await getCollection("links", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const toolIconBase =
  "https://unpkg.com/@lobehub/icons-static-svg@1.86.0/icons";
const toolIcons = [
  { label: "Claude Code", icon: "claudecode", url: "https://claude.ai/code" },
  { label: "Codex", icon: "codex", url: "https://openai.com/codex/" },
  { label: "Gemini CLI", icon: "geminicli", url: "https://github.com/google-gemini/gemini-cli" },
  { label: "Gemini", icon: "gemini", url: "https://gemini.google.com/" },
  { label: "Perplexity", icon: "perplexity", url: "https://www.perplexity.ai/" },
  { label: "OpenRouter", icon: "openrouter", url: "https://openrouter.ai/" },
  { label: "Ollama", icon: "ollama", url: "https://ollama.com/" },
  { label: "OpenCode", icon: "opencode", url: "https://opencode.ai/" },
  { label: "Hugging Face", icon: "huggingface", url: "https://huggingface.co/" },
  { label: "Midjourney", icon: "midjourney", url: "https://www.midjourney.com/" },
  { label: "Recraft", icon: "recraft", url: "https://www.recraft.ai/" },
  { label: "ElevenLabs", icon: "elevenlabs", url: "https://elevenlabs.io/" },
  { label: "NotebookLM", icon: "notebooklm", url: "https://notebooklm.google/" },
  { label: "Manus", icon: "manus", url: "https://manus.im/" },
  { label: "Lovart", icon: "lovart", url: "https://www.lovart.ai/" },
  { label: "Jira AI", icon: "atlascloud", url: "https://www.atlassian.com/software/jira/ai" },
];

const noteCardVariants = ["cell--note-1", "cell--note-2", "cell--note-3"];
const noteCols = 3;
const getNoteVariant = (i: number) =>
  noteCardVariants[(i + Math.floor(i / noteCols)) % noteCardVariants.length];
const noteTilts = ["-1.8deg", "1.2deg", "-0.9deg", "1.6deg", "-1.3deg", "0.8deg", "-0.6deg", "1deg"];
const getNoteTilt = (i: number) => noteTilts[(i * 7 + 3) % noteTilts.length];
---

<BaseLayout title="ジンコウチノウ — NOPE" description="Notes, tools, and links on artificial intelligence.">
  <div class="ai-page">

    <!-- NOTES -->
    {notes.length > 0 && (
      <section class="ai-section">
        <div class="section-header">
          <h2 class="section-label">Notes</h2>
          <a href="/artificial/notes" class="view-all">All notes →</a>
        </div>
        <div class="notes-grid">
          {notes.slice(0, 6).map((note, i) => (
            <button
              type="button"
              class={`cell cell--lift cell--note ${getNoteVariant(i)}`}
              style={`--note-tilt: ${getNoteTilt(i)};`}
              data-lift-max="12"
              popovertarget={note.popoverId}
            >
              <div class="cell__top">
                <p class="cell__meta cell__eyebrow">
                  {note.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
                <h3 class="cell__title">{note.data.title}</h3>
              </div>
            </button>
          ))}
        </div>

        {notes.slice(0, 6).map((note) => (
          <div id={note.popoverId} popover class="note-popover">
            <header class="note-popover__header">
              <div class="note-popover__meta">
                <span class="cell__meta">
                  {note.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
              </div>
              <button
                type="button"
                class="note-popover__close"
                popovertarget={note.popoverId}
                popovertargetaction="hide"
                aria-label="Close"
              >✕</button>
            </header>
            <h2 class="note-popover__title">{note.data.title}</h2>
            <div class="note-popover__body">
              <note.Content />
            </div>
            <a href="/artificial/notes" class="note-popover__link">see all notes →</a>
          </div>
        ))}
      </section>
    )}

    <!-- TOOLS -->
    <section class="ai-section">
      <h2 class="section-label">Tools i use</h2>
      <ul class="tools-grid" aria-label="AI tools">
        {toolIcons.map((tool) => (
          <li class="tool-icon-cell">
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="tool-icon-link"
              title={tool.label}
              aria-label={tool.label}
            >
              <span
                class="tool-icon"
                style={`--tool-icon: url("${toolIconBase}/${tool.icon}.svg")`}
                aria-hidden="true"
              ></span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- LINKS -->
    {links.length > 0 && (
      <section class="ai-section">
        <h2 class="section-label">Links</h2>
        <ul class="links-list">
          {links.map((link) => (
            <li>
              <a
                href={link.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="link-row"
              >
                <span class="link-row__title">{link.data.title}</span>
                {link.data.description && (
                  <span class="link-row__desc cell__meta">{link.data.description}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .ai-page {
    padding: var(--space-12) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  /* ── Section labels ── */
  .ai-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .section-label {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .view-all {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .view-all:hover {
    color: var(--color-text-primary);
  }

  /* ── Base cell (mirrors writing/index.astro) ── */
  .cell {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    text-transform: uppercase;
  }

  .cell--lift {
    --_tx: 0px;
    --_ty: 0px;
    --_scale: 1;
    transform: translate(var(--_tx), var(--_ty)) scale(var(--_scale));
    transform-origin: center;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  /* Notes variant */
  .cell--note {
    border: none;
    box-shadow: 0 0.3rem 1rem rgba(0, 0, 0, 0.08);
    cursor: pointer;
    padding: var(--space-3);
    gap: var(--space-2);
    position: relative;
    overflow: hidden;
    justify-self: center;
    inline-size: min(100%, 15rem);
    min-block-size: 8.5rem;
    text-transform: none;
    filter: none;
  }

  .cell--note-1 {
    background: var(--brand-purple);
    color: var(--neutral-50);
  }

  .cell--note-2 {
    background: var(--neutral-900);
    color: var(--neutral-50);
  }

  .cell--note-3 {
    background: var(--brand-green);
    color: var(--neutral-900);
  }

  .cell--note .cell__title {
    font-size: var(--font-size-sm);
    line-height: 1.15;
    text-transform: none;
    max-inline-size: 16ch;
  }

  .cell--note .cell__meta {
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    opacity: 0.58;
  }

  /* ── Cell internals ── */
  .cell__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cell__eyebrow {
    margin: 0;
  }

  .cell__title {
    margin: 0;
    font-family: var(--font-newsreader);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
  }

  .cell__desc {
    margin: 0;
    line-height: var(--line-height-relaxed);
    text-transform: none;
  }

  .cell__meta {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    line-height: var(--line-height-relaxed);
    color: currentColor;
    opacity: 0.62;
  }

  /* ── Note card button reset ── */
  button.cell--note {
    width: 100%;
    text-align: left;
    font: inherit;
    cursor: pointer;
  }

  button.cell--note:hover {
    border-color: transparent;
  }

  .cell--note.cell--lift {
    transform:
      translate(var(--_tx), var(--_ty))
      rotate(var(--note-tilt, 0deg))
      scale(var(--_scale));
  }

  /* ── Note popover ── */
  :global(.note-popover:popover-open) {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(560px, calc(100vw - var(--space-8)));
    max-height: min(80svh, 600px);
    overflow-y: auto;
    padding: var(--space-8) var(--space-8) var(--space-12);
    background: var(--color-background-surface);
    border: none;
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  :global(.note-popover::backdrop) {
    background: rgba(242, 240, 239, 0.7);
    backdrop-filter: blur(6px);
  }

  :global(.note-popover__header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  :global(.note-popover__meta) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }

  :global(.note-popover__close) {
    flex: none;
    background: none;
    border: none;
    font: inherit;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  :global(.note-popover__close:hover) {
    color: var(--color-text-primary);
  }

  :global(.note-popover__link) {
    align-self: flex-end;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    line-height: var(--line-height-tight);
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-top: var(--space-2);
  }

  :global(.note-popover__link:hover) {
    color: var(--color-text-primary);
  }

  :global(.note-popover__title) {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
  }

  :global(.note-popover__body) {
    font-family: var(--font-newsreader);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  :global(.note-popover__body p) {
    margin: 0 0 var(--space-3);
  }

  :global(.note-popover__body p:last-child) {
    margin-bottom: 0;
  }

  /* ── Notes grid ── */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12.5rem, 1fr));
    align-items: stretch;
    gap: var(--space-2);
    padding-top: var(--space-2);
    overflow: visible;
    padding-bottom: 0;
  }

  .notes-grid > * {
    justify-self: stretch;
  }

  /* ── Tools grid ── */
  .tools-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(2.8rem, 1fr));
    gap: var(--space-2);
  }

  .tool-icon-cell {
    inline-size: 2.8rem;
    block-size: 2.8rem;
    border: var(--border-width-1) solid var(--color-border-default);
    background: var(--color-background-surface);
  }

  .tool-icon-link {
    inline-size: 100%;
    block-size: 100%;
    display: grid;
    place-items: center;
    text-decoration: none;
    color: inherit;
  }

  .tool-icon {
    inline-size: 1.2rem;
    block-size: 1.2rem;
    display: block;
    background-color: var(--color-text-primary);
    opacity: 0.84;
    -webkit-mask-image: var(--tool-icon);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    mask-image: var(--tool-icon);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
  }

  /* ── Links list ── */
  .links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border-width-1) solid var(--color-border-default);
  }

  .links-list li {
    border-bottom: var(--border-width-1) solid var(--color-border-default);
  }

  .link-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) 0;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: background 0.1s ease;
  }

  .link-row:hover {
    background: var(--color-background-subtle);
  }

  .link-row__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .link-row__desc {
    text-transform: none;
    font-size: var(--font-size-xs);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-text-secondary);
    opacity: 0.62;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .notes-grid > * {
      inline-size: 100%;
    }

    .tools-grid {
      grid-template-columns: repeat(auto-fill, minmax(2.6rem, 1fr));
    }
  }

  @media (max-width: 480px) {
    .ai-page {
      padding: var(--space-8) var(--space-4);
    }

    .tools-grid {
      grid-template-columns: repeat(auto-fill, minmax(2.4rem, 1fr));
      gap: var(--space-1);
    }

    .tool-icon-cell {
      inline-size: 2.4rem;
      block-size: 2.4rem;
    }

    .tool-icon {
      inline-size: 1rem;
      block-size: 1rem;
    }

    .notes-grid {
      gap: var(--space-2);
      padding-top: var(--space-1);
      overflow: visible;
    }

    .cell--note {
      inline-size: 100%;
      min-block-size: 5rem;
      padding: var(--space-2);
    }

    .cell--note .cell__title {
      max-inline-size: none;
    }

  }

  @media (hover: hover) and (pointer: fine) {
    .cell--lift:is(:hover, :focus-visible) {
      z-index: 2;
    }
  }

  @media (max-width: 768px) {
    .cell--lift {
      transition: none;
    }

    .cell--note.cell--lift {
      transform: rotate(var(--note-tilt, 0deg));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cell--lift {
      transition: none;
    }

  }
</style>

<script>
  {
    let cleanup: (() => void) | undefined;

    const canUseLift = () =>
      window.matchMedia("(min-width: 769px)").matches &&
      window.matchMedia("(hover: hover) and (pointer: fine)").matches &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const reset = (cell: HTMLElement) => {
      cell.style.setProperty("--_tx", "0px");
      cell.style.setProperty("--_ty", "0px");
      cell.style.setProperty("--_scale", "1");
    };

    function initLift() {
      const cells = document.querySelectorAll<HTMLElement>(".ai-page .cell--lift");
      if (!cells.length || !canUseLift()) {
        cells.forEach(reset);
        return () => {
          cells.forEach(reset);
        };
      }

      const controller = new AbortController();
      const { signal } = controller;

      cells.forEach((cell) => {
        const max = Number(cell.dataset.liftMax ?? 14);

        cell.addEventListener("mousemove", (e) => {
          const rect = cell.getBoundingClientRect();
          const nx = (e.clientX - rect.left) / rect.width;
          const ny = (e.clientY - rect.top) / rect.height;
          cell.style.setProperty("--_tx", `${nx * max}px`);
          cell.style.setProperty("--_ty", `${-(ny * max)}px`);
          cell.style.setProperty("--_scale", "1.04");
        }, { signal });

        cell.addEventListener("mouseleave", () => reset(cell), { signal });
      });

      return () => {
        controller.abort();
        cells.forEach(reset);
      };
    }

    function init() {
      cleanup?.();

      const cleanups = [initLift()];
      cleanup = () => {
        cleanups.forEach((fn) => fn?.());
      };
    }

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-swap", () => cleanup?.(), { once: true });
    init();
  }

  let justClosed = false;

  document.addEventListener("pointerdown", (e) => {
    const open = document.querySelector<HTMLElement>(".note-popover:popover-open");
    if (!open) return;
    if (open.contains(e.target as Node)) return;
    justClosed = true;
    open.hidePopover();
  }, { capture: true });

  document.addEventListener("click", (e) => {
    if (!justClosed) return;
    justClosed = false;
    e.preventDefault();
    e.stopImmediatePropagation();
  }, { capture: true });
</script>
