---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const all = await getCollection("artificial", ({ data }) => !data.draft);

const notes = await Promise.all(
  all
    .filter((e) => e.data.kind === "note")
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map(async (note) => {
      const { Content } = await render(note);
      const popoverId = `note-${note.id.replace(/[^a-z0-9]/gi, "-")}`;
      return { ...note, Content, popoverId };
    })
);

const tools = all
  .filter((e) => e.data.kind === "tool")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const links = all
  .filter((e) => e.data.kind === "link")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const toolIconBase =
  "https://unpkg.com/@lobehub/icons-static-svg@1.86.0/icons";
const featuredToolTitlesDesktop = [
  "Claude Code",
  "Codex",
  "Gemini",
  "Perplexity",
  "OpenRouter",
  "Ollama",
];

const featuredToolTitlesMobile = featuredToolTitlesDesktop.slice(0, 2);

const featuredToolsDesktop = featuredToolTitlesDesktop
  .map((title) => tools.find((tool) => tool.data.title === title))
  .filter(Boolean);

const featuredToolsMobile = featuredToolTitlesMobile
  .map((title) => tools.find((tool) => tool.data.title === title))
  .filter(Boolean);

const moreToolsDesktop = tools.filter(
  (tool) => !featuredToolTitlesDesktop.includes(tool.data.title),
);

const moreToolsMobile = tools.filter(
  (tool) => !featuredToolTitlesMobile.includes(tool.data.title),
);
---

<BaseLayout title="ジンコウチノウ — NOPE" description="Notes, tools, and links on artificial intelligence.">
  <div class="ai-page">

    <!-- NOTES -->
    {notes.length > 0 && (
      <section class="ai-section">
        <div class="section-header">
          <h2 class="section-label">Notes</h2>
          <a href="/notes" class="view-all">All notes →</a>
        </div>
        <div class="notes-grid">
          {notes.slice(0, 3).map((note) => (
            <button
              type="button"
              class="cell cell--lift cell--note"
              data-lift-max="12"
              popovertarget={note.popoverId}
            >
              <div class="cell__top">
                <p class="cell__meta cell__eyebrow">
                  {note.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
                <h3 class="cell__title">{note.data.title}</h3>
              </div>
              {note.data.tags.length > 0 && (
                <ul class="tag-list cell__meta">
                  {note.data.tags.map((tag) => <li class="tag">{tag}</li>)}
                </ul>
              )}
            </button>
          ))}
        </div>

        {notes.slice(0, 3).map((note) => (
          <div id={note.popoverId} popover class="note-popover">
            <header class="note-popover__header">
              <div class="note-popover__meta">
                <span class="cell__meta">
                  {note.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
                {note.data.tags.length > 0 && (
                  <ul class="tag-list cell__meta">
                    {note.data.tags.map((tag) => <li class="tag">{tag}</li>)}
                  </ul>
                )}
              </div>
              <button
                type="button"
                class="note-popover__close"
                popovertarget={note.popoverId}
                popovertargetaction="hide"
                aria-label="Close"
              >✕</button>
            </header>
            <h2 class="note-popover__title">{note.data.title}</h2>
            <div class="note-popover__body">
              <note.Content />
            </div>
            <a href="/notes" class="note-popover__link">see all notes →</a>
          </div>
        ))}
      </section>
    )}

    <!-- TOOLS -->
    {tools.length > 0 && (
      <section class="ai-section">
        <h2 class="section-label">Tools</h2>
        <div class="tools-block tools-block--desktop">
          <div class="tools-grid">
            {featuredToolsDesktop.map((tool) => (
              <a
                href={tool.data.url ?? "#"}
                target={tool.data.url ? "_blank" : undefined}
                rel={tool.data.url ? "noopener noreferrer" : undefined}
                class="cell cell--lift cell--tool"
                data-lift-max="14"
              >
                <div class="cell__top">
                  <div
                    class="tool-card__header"
                    style={tool.data.icon
                      ? `--tool-icon: url("${toolIconBase}/${tool.data.icon}.svg")`
                      : undefined}
                  >
                    {tool.data.icon && <span class="tool-card__icon" aria-hidden="true"></span>}
                    <h3 class="cell__title">{tool.data.title}</h3>
                  </div>
                  {tool.data.description && (
                    <p class="cell__desc cell__meta">{tool.data.description}</p>
                  )}
                </div>
                {tool.data.url && (
                  <p class="cell__meta cell__domain">
                    {new URL(tool.data.url).hostname.replace("www.", "")}
                  </p>
                )}
              </a>
            ))}
          </div>

          {moreToolsDesktop.length > 0 && (
            <details class="tools-more">
              <summary class="tools-more__summary cell__meta">
                <span class="tools-more__label tools-more__label--closed">
                  Show more tools ({moreToolsDesktop.length})
                </span>
                <span class="tools-more__label tools-more__label--open">
                  Hide extra tools
                </span>
              </summary>
              <div class="tools-more__content">
                <div class="tools-grid tools-grid--more">
                  {moreToolsDesktop.map((tool) => (
                    <a
                      href={tool.data.url ?? "#"}
                      target={tool.data.url ? "_blank" : undefined}
                      rel={tool.data.url ? "noopener noreferrer" : undefined}
                      class="cell cell--lift cell--tool"
                      data-lift-max="14"
                    >
                      <div class="cell__top">
                        <div
                          class="tool-card__header"
                          style={tool.data.icon
                            ? `--tool-icon: url("${toolIconBase}/${tool.data.icon}.svg")`
                            : undefined}
                        >
                          {tool.data.icon && <span class="tool-card__icon" aria-hidden="true"></span>}
                          <h3 class="cell__title">{tool.data.title}</h3>
                        </div>
                        {tool.data.description && (
                          <p class="cell__desc cell__meta">{tool.data.description}</p>
                        )}
                      </div>
                      {tool.data.url && (
                        <p class="cell__meta cell__domain">
                          {new URL(tool.data.url).hostname.replace("www.", "")}
                        </p>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            </details>
          )}
        </div>

        <div class="tools-block tools-block--mobile">
          <div class="tools-grid">
            {featuredToolsMobile.map((tool) => (
              <a
                href={tool.data.url ?? "#"}
                target={tool.data.url ? "_blank" : undefined}
                rel={tool.data.url ? "noopener noreferrer" : undefined}
                class="cell cell--lift cell--tool"
                data-lift-max="14"
              >
                <div class="cell__top">
                  <div
                    class="tool-card__header"
                    style={tool.data.icon
                      ? `--tool-icon: url("${toolIconBase}/${tool.data.icon}.svg")`
                      : undefined}
                  >
                    {tool.data.icon && <span class="tool-card__icon" aria-hidden="true"></span>}
                    <h3 class="cell__title">{tool.data.title}</h3>
                  </div>
                  {tool.data.description && (
                    <p class="cell__desc cell__meta">{tool.data.description}</p>
                  )}
                </div>
                {tool.data.url && (
                  <p class="cell__meta cell__domain">
                    {new URL(tool.data.url).hostname.replace("www.", "")}
                  </p>
                )}
              </a>
            ))}
          </div>

          {moreToolsMobile.length > 0 && (
            <details class="tools-more">
              <summary class="tools-more__summary cell__meta">
                <span class="tools-more__label tools-more__label--closed">
                  Show more tools ({moreToolsMobile.length})
                </span>
                <span class="tools-more__label tools-more__label--open">
                  Hide extra tools
                </span>
              </summary>
              <div class="tools-more__content">
                <div class="tools-grid tools-grid--more">
                  {moreToolsMobile.map((tool) => (
                    <a
                      href={tool.data.url ?? "#"}
                      target={tool.data.url ? "_blank" : undefined}
                      rel={tool.data.url ? "noopener noreferrer" : undefined}
                      class="cell cell--lift cell--tool"
                      data-lift-max="14"
                    >
                      <div class="cell__top">
                        <div
                          class="tool-card__header"
                          style={tool.data.icon
                            ? `--tool-icon: url("${toolIconBase}/${tool.data.icon}.svg")`
                            : undefined}
                        >
                          {tool.data.icon && <span class="tool-card__icon" aria-hidden="true"></span>}
                          <h3 class="cell__title">{tool.data.title}</h3>
                        </div>
                        {tool.data.description && (
                          <p class="cell__desc cell__meta">{tool.data.description}</p>
                        )}
                      </div>
                      {tool.data.url && (
                        <p class="cell__meta cell__domain">
                          {new URL(tool.data.url).hostname.replace("www.", "")}
                        </p>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            </details>
          )}
        </div>
      </section>
    )}

    <!-- LINKS -->
    {links.length > 0 && (
      <section class="ai-section">
        <h2 class="section-label">Links</h2>
        <ul class="links-list">
          {links.map((link) => (
            <li>
              <a
                href={link.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="link-row"
              >
                <span class="link-row__title">{link.data.title}</span>
                {link.data.description && (
                  <span class="link-row__desc cell__meta">{link.data.description}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .ai-page {
    padding: var(--space-12) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  /* ── Section labels ── */
  .ai-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .section-label {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .view-all {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .view-all:hover {
    color: var(--color-text-primary);
  }

  /* ── Base cell (mirrors writing/index.astro) ── */
  .cell {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    text-transform: uppercase;
  }

  .cell--lift {
    --_tx: 0px;
    --_ty: 0px;
    --_scale: 1;
    transform: translate(var(--_tx), var(--_ty)) scale(var(--_scale));
    transform-origin: center;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  /* Notes variant */
  .cell--note {
    --note-paper: color-mix(
      in oklch,
      var(--color-background-surface) 82%,
      var(--brand-green) 18%
    );
    --note-border: color-mix(
      in oklch,
      var(--note-paper) 78%,
      var(--color-text-primary)
    );
    --note-shadow: color-mix(
      in oklch,
      var(--color-text-primary) 14%,
      transparent
    );
    --note-pin: color-mix(
      in oklch,
      var(--brand-purple) 38%,
      var(--color-text-primary)
    );
    --note-rotate: -1.4deg;

    background:
      linear-gradient(
        180deg,
        color-mix(in oklch, var(--note-paper) 92%, white) 0%,
        var(--note-paper) 100%
      );
    color: var(--color-text-primary);
    border: var(--border-width-1) solid var(--note-border);
    box-shadow:
      0 0.35rem 0.9rem var(--note-shadow),
      0 0.05rem 0 color-mix(in oklch, var(--note-border) 72%, transparent);
    cursor: pointer;
    padding: var(--space-3);
    gap: var(--space-2);
    position: relative;
    overflow: visible;
    justify-self: center;
    inline-size: min(100%, 15rem);
    min-block-size: 8.5rem;
    text-transform: none;
    filter: saturate(0.94);
  }

  .cell--note .cell__title {
    font-size: var(--font-size-sm);
    line-height: 1.15;
    text-transform: none;
    max-inline-size: 16ch;
  }

  .cell--note .cell__meta {
    letter-spacing: 0.08em;
  }

  .cell--note .tag-list {
    gap: var(--space-1);
  }

  .cell--note .tag {
    text-transform: lowercase;
  }

  .cell--note::before {
    content: "";
    position: absolute;
    inset-block-start: calc(var(--space-2) * -1);
    inset-inline-start: 50%;
    inline-size: 0.8rem;
    block-size: 0.8rem;
    border-radius: 999px;
    background: var(--color-text-primary);
    transform: translateX(-50%);
    z-index: 2;
    pointer-events: none;
  }

  .cell--note::after {
    content: "";
    position: absolute;
    inset-block-start: var(--space-2);
    inset-inline-end: var(--space-3);
    inline-size: 2.5rem;
    block-size: 0.85rem;
    background: color-mix(in oklch, var(--color-background) 76%, white);
    border: 1px solid color-mix(in oklch, var(--color-text-primary) 10%, transparent);
    opacity: 0.88;
    transform: rotate(8deg);
    box-shadow: 0 0.12rem 0.35rem rgba(0, 0, 0, 0.05);
    pointer-events: none;
  }

  .cell--tool {
    background: var(--color-text-primary);
    color: var(--color-text-inverse);
    border: var(--border-width-1) solid var(--color-text-primary);
    gap: var(--space-2);
    padding: var(--space-3);
  }

  .cell--tool .cell__top {
    gap: var(--space-2);
  }

  .tool-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
  }

  .tool-card__icon {
    width: 1rem;
    height: 1rem;
    flex: none;
    background-color: currentColor;
    opacity: 0.78;
    -webkit-mask-image: var(--tool-icon);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    mask-image: var(--tool-icon);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
  }

  .cell--tool .cell__title {
    font-size: var(--font-size-sm);
    overflow-wrap: anywhere;
  }

  .cell--tool .cell__desc,
  .cell--tool .cell__meta {
    font-size: var(--font-size-xs);
    line-height: var(--line-height-tight);
  }

  /* ── Cell internals ── */
  .cell__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cell__eyebrow {
    margin: 0;
  }

  .cell__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
  }

  .cell__desc {
    margin: 0;
    line-height: var(--line-height-relaxed);
    text-transform: none;
  }

  .cell__meta {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    line-height: var(--line-height-relaxed);
    color: currentColor;
    opacity: 0.62;
  }

  .cell__domain {
    margin: 0;
    text-transform: lowercase;
  }

  /* ── Note card button reset ── */
  button.cell--note {
    width: 100%;
    text-align: left;
    background: inherit;
    border: inherit;
    font: inherit;
    cursor: pointer;
  }

  button.cell--note:hover {
    border-color: var(--note-border);
  }

  .cell--note.cell--lift {
    transform:
      translate(var(--_tx), var(--_ty))
      rotate(var(--note-rotate))
      scale(var(--_scale));
  }

  .notes-grid > :nth-child(3n + 1) {
    --note-paper: color-mix(
      in oklch,
      var(--color-background-surface) 80%,
      var(--brand-green) 20%
    );
    --note-rotate: -2.2deg;
  }

  .notes-grid > :nth-child(3n + 2) {
    --note-paper: color-mix(
      in oklch,
      var(--color-background-surface) 88%,
      var(--brand-purple) 12%
    );
    --note-rotate: 1.4deg;
  }

  .notes-grid > :nth-child(3n) {
    --note-paper: color-mix(
      in oklch,
      var(--color-background-surface) 94%,
      var(--neutral-warm-600) 6%
    );
    --note-rotate: -0.6deg;
  }

  /* ── Note popover ── */
  :global(.note-popover:popover-open) {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(560px, calc(100vw - var(--space-8)));
    max-height: min(80svh, 600px);
    overflow-y: auto;
    padding: var(--space-8) var(--space-8) var(--space-12);
    background: var(--color-background-surface);
    border: none;
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  :global(.note-popover::backdrop) {
    background: rgba(242, 240, 239, 0.7);
    backdrop-filter: blur(6px);
  }

  :global(.note-popover__header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  :global(.note-popover__meta) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }

  :global(.note-popover__close) {
    flex: none;
    background: none;
    border: none;
    font: inherit;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  :global(.note-popover__close:hover) {
    color: var(--color-text-primary);
  }

  :global(.note-popover__link) {
    align-self: flex-end;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    line-height: var(--line-height-tight);
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-top: var(--space-2);
  }

  :global(.note-popover__link:hover) {
    color: var(--color-text-primary);
  }

  :global(.note-popover__title) {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
  }

  :global(.note-popover__body) {
    font-family: var(--font-newsreader);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  :global(.note-popover__body p) {
    margin: 0 0 var(--space-3);
  }

  :global(.note-popover__body p:last-child) {
    margin-bottom: 0;
  }

  /* ── Notes grid ── */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(9rem, auto);
    gap: var(--space-3);
    padding-top: var(--space-2);
  }

  /* ── Tools grid ── */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(7.5rem, auto);
    gap: var(--space-2);
  }

  .tools-block--mobile {
    display: none;
  }

  .tools-more {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
    interpolate-size: allow-keywords;
  }

  .tools-more::details-content {
    block-size: 0;
    opacity: 0;
    overflow: clip;
    transition:
      content-visibility 280ms allow-discrete,
      block-size 280ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .tools-more[open]::details-content {
    block-size: auto;
    opacity: 1;
  }

  @starting-style {
    .tools-more[open]::details-content {
      block-size: 0;
      opacity: 0;
    }
  }

  .tools-more__summary {
    cursor: pointer;
    list-style: none;
    width: fit-content;
  }

  .tools-more__summary::-webkit-details-marker {
    display: none;
  }

  .tools-more__summary::before {
    content: "+ ";
  }

  .tools-more[open] .tools-more__summary::before {
    content: "- ";
  }

  .tools-more__label--open {
    display: none;
  }

  .tools-more[open] .tools-more__label--closed {
    display: none;
  }

  .tools-more[open] .tools-more__label--open {
    display: inline;
  }

  .tools-grid--more {
    padding-top: var(--space-1);
  }

  /* ── Tags ── */
  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  /* ── Links list ── */
  .links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border-width-1) solid var(--color-border-default);
  }

  .links-list li {
    border-bottom: var(--border-width-1) solid var(--color-border-default);
  }

  .link-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) 0;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: background 0.1s ease;
  }

  .link-row:hover {
    background: var(--color-background-subtle);
  }

  .link-row__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .link-row__desc {
    text-transform: none;
    font-size: var(--font-size-xs);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-text-secondary);
    opacity: 0.62;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .notes-grid,
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(7rem, auto);
    }

  }

  @media (max-width: 480px) {
    .ai-page {
      padding: var(--space-8) var(--space-4);
    }

    .tools-block--desktop {
      display: none;
    }

    .tools-block--mobile {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .notes-grid,
    .tools-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: minmax(12rem, auto);
    }

    .notes-grid {
      grid-auto-rows: minmax(7rem, auto);
      gap: var(--space-2);
      padding-top: var(--space-1);
    }

    .cell--note {
      inline-size: 100%;
      min-block-size: 7rem;
      padding: var(--space-2) var(--space-3);
    }

    .cell--note .cell__title {
      max-inline-size: none;
    }

    .cell--note::after {
      inline-size: 2rem;
      block-size: 0.7rem;
    }

    .tools-grid {
      grid-auto-rows: minmax(6.5rem, auto);
    }

  }

  @media (hover: hover) and (pointer: fine) {
    .cell--lift:is(:hover, :focus-visible) {
      z-index: 2;
    }
  }

  @media (max-width: 768px) {
    .cell--lift {
      transform: none;
      transition: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cell--lift {
      transition: none;
    }

    .tools-more::details-content {
      transition: none;
    }
  }
</style>

<script>
  {
    let cleanup: (() => void) | undefined;

    const canUseLift = () =>
      window.matchMedia("(min-width: 769px)").matches &&
      window.matchMedia("(hover: hover) and (pointer: fine)").matches &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const reset = (cell: HTMLElement) => {
      cell.style.setProperty("--_tx", "0px");
      cell.style.setProperty("--_ty", "0px");
      cell.style.setProperty("--_scale", "1");
    };

    function initLift() {
      const cells = document.querySelectorAll<HTMLElement>(".ai-page .cell--lift");
      if (!cells.length || !canUseLift()) {
        cells.forEach(reset);
        return () => {
          cells.forEach(reset);
        };
      }

      const controller = new AbortController();
      const { signal } = controller;

      cells.forEach((cell) => {
        const max = Number(cell.dataset.liftMax ?? 14);

        cell.addEventListener("mousemove", (e) => {
          const rect = cell.getBoundingClientRect();
          const nx = (e.clientX - rect.left) / rect.width;
          const ny = (e.clientY - rect.top) / rect.height;
          cell.style.setProperty("--_tx", `${nx * max}px`);
          cell.style.setProperty("--_ty", `${-(ny * max)}px`);
          cell.style.setProperty("--_scale", "1.04");
        }, { signal });

        cell.addEventListener("mouseleave", () => reset(cell), { signal });
      });

      return () => {
        controller.abort();
        cells.forEach(reset);
      };
    }

    function init() {
      cleanup?.();

      const cleanups = [initLift()];
      cleanup = () => {
        cleanups.forEach((fn) => fn?.());
      };
    }

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-swap", () => cleanup?.(), { once: true });
    init();
  }

  let justClosed = false;

  document.addEventListener("pointerdown", (e) => {
    const open = document.querySelector<HTMLElement>(".note-popover:popover-open");
    if (!open) return;
    if (open.contains(e.target as Node)) return;
    justClosed = true;
    open.hidePopover();
  }, { capture: true });

  document.addEventListener("click", (e) => {
    if (!justClosed) return;
    justClosed = false;
    e.preventDefault();
    e.stopImmediatePropagation();
  }, { capture: true });
</script>
