  interface AnimatedScreen {
    kind: DisplayMediaKind;
    pos: Vector3;
    material: MeshBasicMaterial;
    textures?: Texture[];
    currentIndex?: number;
    lastSwapAt?: number;
  }

  const displays: DisplayMarker[] = [];
  const animatedScreens: AnimatedScreen[] = [];

  function localOffsetToWorld(x: number, z: number, rotY: number, localX: number, localZ: number) {
    const cos = Math.cos(rotY);
    const sin = Math.sin(rotY);
    return {
      x: x + localX * cos + localZ * sin,
      z: z - localX * sin + localZ * cos,
    };
  }

  function loadTexture(url: string, onLoad: (texture: Texture) => void, onError?: () => void) {
    textureLoader.load(
      encodeURI(url),
      (texture) => {
      texture.colorSpace = SRGBColorSpace;
      texture.anisotropy = maxAnisotropy;
        onLoad(texture);
      },
      undefined,
      () => {
        onError?.();
      }
    );
  }

  function contentMeta(kind: DisplayMediaKind) {
    if (kind === 'slideshow') return 'Image Sequence';
    return 'Still Image';
  }

  function createScreenMaterial(
    accentColor: string,
    mediaKind: DisplayMediaKind,
    imageSrc: string,
    imageSources: string[],
    title: string,
    position: Vector3
  ) {
    const material = new MeshBasicMaterial({
      color: imageSrc ? 0xffffff : accentColor,
      side: DoubleSide,
    });

    if (mediaKind === 'slideshow' && imageSources.length > 0) {
      const textures: Texture[] = [];
      imageSources.forEach((source, index) => {
        loadTexture(
          source,
          (texture) => {
            textures[index] = texture;
            if (!material.map) {
              material.map = texture;
              material.color.set(0xffffff);
              material.needsUpdate = true;
            }
          },
          () => {
            console.error(`Failed to load gallery slideshow image for "${title}"`);
          }
        );
      });

      animatedScreens.push({
        kind: 'slideshow',
        pos: position.clone(),
        material,
        textures,
        currentIndex: 0,
        lastSwapAt: performance.now(),
      });

      return material;
    }

    if (imageSrc) {
      loadTexture(
        imageSrc,
        (texture) => {
          material.map = texture;
          material.color.set(0xffffff);
          material.needsUpdate = true;
        },
        () => {
          console.error(`Failed to load gallery image for "${title}"`);
          material.color.set(accentColor);
          material.needsUpdate = true;
        }
      );
    }

    return material;
  }

  function displayMeta(kind: DisplayKind, mediaKind: DisplayMediaKind) {
    const hardware = kind === 'wall-panel'
      ? 'Wall Panel'
      : kind === 'wall-monitor'
        ? 'Studio Monitor'
        : 'CRT Installation';
    return `${hardware} · ${contentMeta(mediaKind)}`;
  }

  function wiringSeed(title: string) {
    let hash = 0;
    for (let i = 0; i < title.length; i += 1) {
      hash = ((hash << 5) - hash) + title.charCodeAt(i);
      hash |= 0;
    }
    return Math.abs(hash);
  }

  function addWallJack(
    group: Group,
    x: number,
    y: number,
    z: number,
    normalSign: number
  ) {
    const plate = new Mesh(
      new BoxGeometry(0.18, 0.26, 0.02),
      jackPlateMaterial
    );
    plate.position.set(x, y, z);
    group.add(plate);

    const socket = new Mesh(
      new BoxGeometry(0.06, 0.1, 0.012),
      jackSocketMaterial
    );
    socket.position.set(x, y - 0.015, z + 0.011 * normalSign);
    group.add(socket);
  }

  function addCableRun(
    group: Group,
    points: Array<[number, number, number]>,
    radius = 0.012
  ) {
    const curve = new CatmullRomCurve3(
      points.map(([x, y, z]) => new Vector3(x, y, z))
    );
    const cable = new Mesh(
      new TubeGeometry(curve, 22, radius, 8, false),
      cableMaterial
    );
    group.add(cable);
  }

  function addDisplayWiring(group: Group, options: {
    origin: [number, number, number];
    shellWidth: number;
    shellHeight: number;
    normalSign: number;
    title: string;
    preferLowJack?: boolean;
    minCableY?: number;
  }) {
    const { origin, shellWidth, shellHeight, normalSign, title, preferLowJack = false, minCableY = 0.08 } = options;
    const seed = wiringSeed(title);
    const sideSign = seed % 2 === 0 ? 1 : -1;
    const lateralBase = Math.min(shellWidth * 0.28, 0.62);
    const lateral = (lateralBase + (seed % 4) * 0.06) * sideSign;
    const wallZ = (WALL_THICKNESS / 2 + 0.015) * normalSign;
    const rawDropY = preferLowJack
      ? origin[1] - (0.32 + (seed % 3) * 0.08)
      : -shellHeight / 2 - 0.08 - (seed % 3) * 0.06;
    const dropY = Math.max(rawDropY, minCableY);
    const wallJackY = preferLowJack
      ? 0.26 + (seed % 4) * 0.07
      : -shellHeight / 2 - 0.28 - (seed % 5) * 0.07;
    const wallJackX = lateral;
    const bendX = wallJackX * (0.4 + (seed % 3) * 0.12);
    const bendY = wallJackY + 0.16 + (seed % 3) * 0.05;
    const bendZ = wallZ + (0.03 + (seed % 2) * 0.025) * normalSign;

    addWallJack(group, wallJackX, wallJackY, wallZ, normalSign);
    addCableRun(group, [
      origin,
      [origin[0], dropY, origin[2] - 0.04 * normalSign],
      [bendX, bendY, bendZ],
      [wallJackX, wallJackY, wallZ + 0.02 * normalSign],
    ], 0.012);
  }

  function createWallDisplay(
    x: number,
    y: number,
    z: number,
    rotY: number,
    width: number,
    height: number,
    title: string,
    desc: string,
    mediaKind: DisplayMediaKind,
    imageSrc: string,
    imageSources: string[],
    tags: string[],
    tech: string[],
    date: string,
    url: string,
    kind: 'wall-panel' | 'wall-monitor',
    facing: WallFacing = 'positive'
  ) {
    const group = new Group();
    const accentColor = tagToColor(tags);
    const normalSign = facing === 'negative' ? -1 : 1;
    const bodyDepth = kind === 'wall-panel' ? 0.22 : 0.34;
    const bezel = kind === 'wall-panel' ? 0.1 : 0.14;
    const shellWidth = width + bezel * 1.35;
    const shellHeight = height + bezel * 1.25;
    const mountDepth = WALL_THICKNESS / 2 + bodyDepth / 2 + 0.035;
    const faceDepth = mountDepth + bodyDepth / 2;
    const displayPosition = new Vector3(x, y, z);
    const screenMat = createScreenMaterial(
      accentColor,
      mediaKind,
      imageSrc,
      imageSources,
      title,
      displayPosition
    );

    const shell = new Mesh(
      new BoxGeometry(shellWidth, shellHeight, bodyDepth),
      darkShellMaterial
    );
    shell.position.z = mountDepth * normalSign;
    group.add(shell);

    const mount = new Mesh(
      new BoxGeometry(Math.max(width * 0.22, 0.24), Math.max(height * 0.18, 0.2), 0.08),
      metalStandMaterial
    );
    mount.position.z = (WALL_THICKNESS / 2 + 0.05) * normalSign;
    group.add(mount);

    const screenHousing = new Mesh(
      new BoxGeometry(width + bezel * 0.75, height + bezel * 0.75, 0.05),
      bezelMaterial
    );
    screenHousing.position.z = (faceDepth - 0.03) * normalSign;
    group.add(screenHousing);

    const screen = new Mesh(
      new PlaneGeometry(width, height),
      screenMat
    );
    screen.position.z = (faceDepth + 0.003) * normalSign;
    if (normalSign < 0) {
      screen.rotation.y = Math.PI;
    }
    group.add(screen);

    const glass = new Mesh(
      new PlaneGeometry(width * 0.985, height * 0.985),
      glassMaterial
    );
    glass.position.z = screen.position.z + 0.006 * normalSign;
    if (normalSign < 0) {
      glass.rotation.y = Math.PI;
    }
    group.add(glass);

    const indicator = new Mesh(
      new BoxGeometry(0.08, 0.02, 0.015),
      new MeshStandardMaterial({
        color: accentColor,
        emissive: accentColor,
        emissiveIntensity: 0.9,
      })
    );
    indicator.position.set(0, -shellHeight / 2 + 0.08, (faceDepth + 0.01) * normalSign);
    group.add(indicator);

    addDisplayWiring(
      group,
      {
        origin: [0, -shellHeight / 2 + 0.06, (mountDepth - bodyDepth * 0.12) * normalSign],
        shellWidth,
        shellHeight,
        normalSign,
        title,
      }
    );

    group.position.set(x, y, z);
    group.rotation.y = rotY;
    scene.add(group);

    const markerPos = localOffsetToWorld(x, z, rotY, 0, (faceDepth + 0.16) * normalSign);
    const labelAnchor = localOffsetToWorld(
      x,
      z,
      rotY,
      shellWidth / 2 + 0.95,
      (faceDepth + 0.12) * normalSign
    );
    displays.push({
      position: new Vector3(markerPos.x, y, markerPos.z),
      labelPosition: new Vector3(labelAnchor.x, y + 0.08, labelAnchor.z),
      title,
      desc,
      tech,
      date,
      accent: accentColor,
      meta: displayMeta(kind, mediaKind),
      url,
    });
  }

  function createCrtDisplay(
    x: number,
    z: number,
    rotY: number,
    width: number,
    height: number,
    title: string,
    desc: string,
    mediaKind: DisplayMediaKind,
    imageSrc: string,
    imageSources: string[],
    tags: string[],
    tech: string[],
    date: string,
    url: string,
    facing: WallFacing = 'positive'
  ) {
    const group = new Group();
    const accentColor = tagToColor(tags);
    const normalSign = facing === 'negative' ? -1 : 1;
    const stoolHeight = 0.82;
    const stoolTopWidth = Math.max(width * 0.78, 1.1);
    const stoolTopDepth = 0.62;
    const tvWidth = width + 0.42;
    const tvHeight = height + 0.5;
    const tvDepth = 0.78;
    const frontOffset = WALL_THICKNESS / 2 + tvDepth / 2 + 0.74;
    const tvCenterY = stoolHeight + tvHeight / 2 + 0.08;
    const screenInset = tvDepth / 2 + 0.006;
    const displayPosition = new Vector3(x, tvCenterY, z);
    const screenMat = createScreenMaterial(
      accentColor,
      mediaKind,
      imageSrc,
      imageSources,
      title,
      displayPosition
    );

    const stoolTop = new Mesh(
      new BoxGeometry(stoolTopWidth, 0.08, stoolTopDepth),
      woodMaterial
    );
    stoolTop.position.set(0, stoolHeight, frontOffset * normalSign);
    group.add(stoolTop);

    const legHeight = stoolHeight;
    const legGeometry = new BoxGeometry(0.08, legHeight, 0.08);
    const legOffsets = [
      [-stoolTopWidth / 2 + 0.08, stoolTopDepth / 2 - 0.08],
      [stoolTopWidth / 2 - 0.08, stoolTopDepth / 2 - 0.08],
      [-stoolTopWidth / 2 + 0.08, -stoolTopDepth / 2 + 0.08],
      [stoolTopWidth / 2 - 0.08, -stoolTopDepth / 2 + 0.08],
    ];
    legOffsets.forEach(([lx, lz]) => {
      const leg = new Mesh(legGeometry, woodMaterial);
      leg.position.set(lx, legHeight / 2, frontOffset * normalSign + lz);
      group.add(leg);
    });

    const tvBody = new Mesh(
      new BoxGeometry(tvWidth, tvHeight, tvDepth),
      shellMaterial
    );
    tvBody.position.set(0, tvCenterY, frontOffset * normalSign);
    group.add(tvBody);

    const screenBezel = new Mesh(
      new BoxGeometry(width + 0.22, height + 0.22, 0.08),
      bezelMaterial
    );
    screenBezel.position.set(0, tvCenterY + 0.02, (frontOffset + (tvDepth / 2 - 0.035)) * normalSign);
    group.add(screenBezel);

    const screen = new Mesh(
      new PlaneGeometry(width, height),
      screenMat
    );
    screen.position.set(0, tvCenterY + 0.02, (frontOffset + screenInset) * normalSign);
    if (normalSign < 0) {
      screen.rotation.y = Math.PI;
    }
    group.add(screen);

    const glass = new Mesh(
      new PlaneGeometry(width * 0.98, height * 0.98),
      glassMaterial
    );
    glass.position.set(0, tvCenterY + 0.02, screen.position.z + 0.008 * normalSign);
    if (normalSign < 0) {
      glass.rotation.y = Math.PI;
    }
    group.add(glass);

    addDisplayWiring(
      group,
      {
        origin: [0, tvCenterY - tvHeight * 0.22, (frontOffset - tvDepth / 2 + 0.02) * normalSign],
        shellWidth: tvWidth,
        shellHeight: tvHeight,
        normalSign,
        title,
        preferLowJack: true,
      }
    );

    group.position.set(x, 0, z);
    group.rotation.y = rotY;
    scene.add(group);

    const colliderPos = localOffsetToWorld(x, z, rotY, 0, frontOffset * normalSign);
    wallColliders.push(
      createBoxCollider(
        colliderPos.x,
        colliderPos.z,
        Math.max(tvWidth, stoolTopWidth),
        tvDepth + 0.24,
        rotY
      )
    );

    const markerPos = localOffsetToWorld(x, z, rotY, 0, (frontOffset + tvDepth / 2 + 0.16) * normalSign);
    const labelAnchor = localOffsetToWorld(
      x,
      z,
      rotY,
      tvWidth / 2 + 1.05,
      (frontOffset + tvDepth / 2 - 0.02) * normalSign
    );
    displays.push({
      position: new Vector3(markerPos.x, tvCenterY, markerPos.z),
      labelPosition: new Vector3(labelAnchor.x, tvCenterY + 0.04, labelAnchor.z),
      title,
      desc,
      tech,
      date,
      accent: accentColor,
      meta: displayMeta('crt-stack', mediaKind),
      url,
    });
  }

  function tagToColor(tags: string[]): string {
    const palette = [
      '#e63946', '#457b9d', '#2a9d8f', '#e9c46a',
      '#9b5de5', '#00b4d8', '#06d6a0', '#f4a261',
      '#ef476f', '#118ab2', '#073b4c', '#f78c6b',
    ];
    if (tags.length === 0) return palette[0];
    let hash = 0;
    for (const tag of tags) {
      for (let i = 0; i < tag.length; i++) {
        hash = tag.charCodeAt(i) + ((hash << 5) - hash);
      }
    }
    return palette[Math.abs(hash) % palette.length];
  }

  // Create displays from work collection data
  const data = displayData as Array<{
    title: string;
    description: string;
    mediaKind: DisplayMediaKind;
    image: string;
    images: string[];
    effort: number;
    tags: string[];
    tech: string[];
    date: string | undefined;
    url: string;
    kind: DisplayKind;
    room: string;
    width: number;
    height: number;
    x: number;
    z: number;
    rotY: number;
    facing: WallFacing;
  }>;

  data.forEach((item) => {
    if (item.kind === 'crt-stack') {
    createCrtDisplay(
      item.x,
      item.z,
      item.rotY,
      item.width,
      item.height,
      item.title,
      item.description,
      item.mediaKind,
      item.image,
      item.images,
      item.tags,
      item.tech,
      item.date,
      item.url,
      item.facing
    );
      return;
    }

    const y = item.kind === 'wall-panel' ? item.height / 2 + 1.02 : item.height / 2 + 1.2;
    createWallDisplay(
      item.x,
      y,
      item.z,
      item.rotY,
      item.width,
      item.height,
      item.title,
      item.description,
      item.mediaKind,
      item.image,
      item.images,
      item.tags,
      item.tech,
      item.date,
      item.url,
      item.kind,
      item.facing
    );
  });

  // Label system
  const labelsContainer = document.getElementById('display-labels')!;
  const labelEls: { el: HTMLDivElement; pos: Vector3; url: string }[] = [];

  displays.forEach((display) => {
    const el = document.createElement('div');
    el.className = 'display-label';
    const year = display.date ? new Date(display.date).getFullYear() : '';
    const techHtml = display.tech?.length
      ? `<span class="display-label-tech">${display.tech.map((t: string) => `<span class="display-label-tech-tag">${t}</span>`).join('')}</span>`
      : '';
    const linkHtml = display.url
      ? `<span class="display-label-link"><kbd>E</kbd> Visit</span>`
      : "";
    el.innerHTML = `
      <span class="display-label-accent" style="background: ${display.accent}"></span>
      <span class="display-label-meta">${display.meta}${year ? ` · ${year}` : ''}</span>
      <span class="display-label-title">${display.title}</span>
      <span class="display-label-desc">${display.desc}</span>
      ${techHtml}
      ${linkHtml}
    `;
    labelsContainer.appendChild(el);
    labelEls.push({ el, pos: display.labelPosition.clone(), url: display.url });
  });

  // Controls
  const controls = new PointerLockControls(camera, document.body);

  const MOUSE_SENSITIVITY = 0.2;
  const euler = new Euler(0, 0, 0, 'YXZ');

  document.addEventListener('mousemove', (e) => {
    if (!controls.isLocked) return;
    euler.setFromQuaternion(camera.quaternion);
    euler.y -= e.movementX * MOUSE_SENSITIVITY * 0.002;
    euler.x -= e.movementY * MOUSE_SENSITIVITY * 0.002;
    euler.x = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, euler.x));
    camera.quaternion.setFromEuler(euler);
  });

  overlay.addEventListener('click', () => controls.lock());
  toggleButton.addEventListener('click', () => controls.lock());
  controls.addEventListener('lock', () => {
    hasExplored = true;
    overlay.classList.add('hidden');
    labelsContainer.classList.add('active');
    syncGalleryChrome(true);
  });
  controls.addEventListener('unlock', () => {
    overlay.classList.remove('hidden');
    labelsContainer.classList.remove('active');
    labelEls.forEach(({ el }) => el.classList.remove('visible'));
    syncGalleryChrome(false);
  });

  // WASD movement
  const keys = { forward: false, backward: false, left: false, right: false };

  document.addEventListener('keydown', (e) => {
    switch (e.code) {
      case 'KeyW': case 'ArrowUp': keys.forward = true; break;
      case 'KeyS': case 'ArrowDown': keys.backward = true; break;
      case 'KeyA': case 'ArrowLeft': keys.left = true; break;
      case 'KeyD': case 'ArrowRight': keys.right = true; break;
      case 'KeyE':
        if (controls.isLocked && activeLabel?.url) {
          window.open(activeLabel.url, '_blank', 'noopener,noreferrer');
        }
        break;
    }
  });
  document.addEventListener('keyup', (e) => {
    switch (e.code) {
      case 'KeyW': case 'ArrowUp': keys.forward = false; break;
      case 'KeyS': case 'ArrowDown': keys.backward = false; break;
      case 'KeyA': case 'ArrowLeft': keys.left = false; break;
      case 'KeyD': case 'ArrowRight': keys.right = false; break;
    }
  });

  // Animation
  let activeLabel: { el: HTMLDivElement; pos: Vector3; dist: number; screenPos: Vector3; url: string } | null = null;
  const velocity = new Vector3();
  const direction = new Vector3();
  const speed = 1;
  let rafId: number;
  let prevTime = performance.now();

  const animate = () => {
    rafId = requestAnimationFrame(animate);
    const time = performance.now();
    const delta = (time - prevTime) / 1000;
    prevTime = time;

    if (controls.isLocked) {
      velocity.x -= velocity.x * 10 * delta;
      velocity.z -= velocity.z * 10 * delta;

      direction.z = Number(keys.forward) - Number(keys.backward);
      direction.x = Number(keys.right) - Number(keys.left);
      direction.normalize();

      if (keys.forward || keys.backward) velocity.z -= direction.z * speed * delta;
      if (keys.left || keys.right) velocity.x -= direction.x * speed * delta;

      const oldX = camera.position.x;
      const oldZ = camera.position.z;

      const forward = new Vector3();
      camera.getWorldDirection(forward);
      forward.y = 0;
      forward.normalize();
      const right = new Vector3();
      right.crossVectors(forward, new Vector3(0, 1, 0)).normalize();

      const worldMove = new Vector3();
      worldMove.addScaledVector(right, -velocity.x);
      worldMove.addScaledVector(forward, -velocity.z);

      const newX = oldX + worldMove.x;
      const newZ = oldZ + worldMove.z;

      if (!checkWallCollision(newX, newZ)) {
        camera.position.x = newX;
        camera.position.z = newZ;
      } else {
        if (!checkWallCollision(newX, oldZ)) {
          camera.position.x = newX;
        }
        if (!checkWallCollision(camera.position.x, newZ)) {
          camera.position.z = newZ;
        }
      }

      camera.position.y = 1.7;
    }

    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const showDist = 5;
    const activeMediaDist = 7;

    activeLabel = null;

    labelEls.forEach(({ el, pos, url }) => {
      el.classList.remove('visible');
      const dist = camera.position.distanceTo(pos);
      if (dist >= showDist) return;

      const screenPos = pos.clone().project(camera);
      if (screenPos.z > 1) return;

      if (!activeLabel || dist < activeLabel.dist) {
        activeLabel = { el, pos, dist, screenPos, url };
      }
    });

    if (activeLabel) {
      const parallaxX = activeLabel.screenPos.x * 18;
      const parallaxY = activeLabel.screenPos.y * 12;
      activeLabel.el.style.left = `${vw - 28 + parallaxX}px`;
      activeLabel.el.style.top = `${vh - 28 + parallaxY}px`;
      activeLabel.el.classList.add('visible');
    }

    animatedScreens.forEach((screen) => {
      const dist = camera.position.distanceTo(screen.pos);

      if (screen.kind === 'slideshow' && screen.textures && screen.textures.length > 1) {
        if (dist < activeMediaDist && time - (screen.lastSwapAt ?? 0) > 3200) {
          let nextIndex = ((screen.currentIndex ?? 0) + 1) % screen.textures.length;
          let guard = 0;
          while (!screen.textures[nextIndex] && guard < screen.textures.length) {
            nextIndex = (nextIndex + 1) % screen.textures.length;
            guard += 1;
          }
          if (screen.textures[nextIndex]) {
            screen.material.map = screen.textures[nextIndex];
            screen.material.needsUpdate = true;
            screen.currentIndex = nextIndex;
            screen.lastSwapAt = time;
          }
        }
      }
    });

    renderer.render(scene, camera);
  };

  animate();

  document.addEventListener('astro:before-swap', () => {
    cancelAnimationFrame(rafId);
    animatedScreens.forEach((screen) => {
      screen.material.map?.dispose();
      if (screen.kind === 'slideshow') {
        screen.textures?.forEach((texture) => texture?.dispose());
      }
    });
    controls.dispose();
    renderer.dispose();
  }, { once: true });
  }

  document.addEventListener('astro:page-load', () => {
    const isMobile = window.matchMedia('(pointer: coarse)').matches;
    if (isMobile) {
      const wrapper = document.getElementById('gallery-wrapper') as HTMLElement | null;
      const mobileWall = document.getElementById('gallery-mobile-wall') as HTMLElement | null;
      if (wrapper) wrapper.hidden = true;
      if (mobileWall) mobileWall.hidden = false;
      return;
    }
    init();
  });
</script>
