  interface WallCollider {
    minX: number; maxX: number;
    minZ: number; maxZ: number;
  }

  const wallColliders: WallCollider[] = [];

  function createBoxCollider(
    x: number,
    z: number,
    length: number,
    depth: number,
    rotY: number
  ): WallCollider {
    const halfLen = length / 2;
    const halfDepth = depth / 2;
    const cos = Math.cos(rotY);
    const sin = Math.sin(rotY);
    const corners = [
      { dx: -halfLen, dz: -halfDepth },
      { dx: halfLen, dz: -halfDepth },
      { dx: -halfLen, dz: halfDepth },
      { dx: halfLen, dz: halfDepth },
    ];
    let minX = Infinity, maxX = -Infinity, minZ = Infinity, maxZ = -Infinity;
    for (const c of corners) {
      const wx = x + c.dx * cos - c.dz * sin;
      const wz = z + c.dx * sin + c.dz * cos;
      if (wx < minX) minX = wx;
      if (wx > maxX) maxX = wx;
      if (wz < minZ) minZ = wz;
      if (wz > maxZ) maxZ = wz;
    }
    return { minX, maxX, minZ, maxZ };
  }

  function createWallCollider(x: number, z: number, length: number, rotY: number): WallCollider {
    return createBoxCollider(x, z, length, WALL_THICKNESS, rotY);
  }

  const PLAYER_RADIUS = 0.3;

  function addLightTrack(
    x: number,
    z: number,
    length: number,
    rotY: number,
    targetPoints: Array<{ x: number; y: number; z: number }>
  ) {
    const track = new Mesh(
      new BoxGeometry(length, 0.08, 0.12),
      trackMaterial
    );
    track.position.set(x, H - 0.35, z);
    track.rotation.y = rotY;
    scene.add(track);

    targetPoints.forEach((targetPoint, index) => {
      const t = targetPoints.length === 1 ? 0.5 : index / (targetPoints.length - 1);
      const localOffset = (t - 0.5) * (length - 0.8);
      const cos = Math.cos(rotY);
      const sin = Math.sin(rotY);
      const lightX = x + localOffset * cos;
      const lightZ = z + localOffset * sin;

      const spot = new SpotLight(0xfff1dc, 14, 14, 0.5, 0.9, 1.5);
      spot.position.set(lightX, H - 0.55, lightZ);

      const target = new Object3D();
      target.position.set(targetPoint.x, targetPoint.y, targetPoint.z);
      spot.target = target;
      scene.add(target);
      scene.add(spot);
    });
  }

  function checkWallCollision(px: number, pz: number): boolean {
    for (const wall of wallColliders) {
      const closestX = Math.max(wall.minX, Math.min(px, wall.maxX));
      const closestZ = Math.max(wall.minZ, Math.min(pz, wall.maxZ));
      const dx = px - closestX;
      const dz = pz - closestZ;
      if (dx * dx + dz * dz < PLAYER_RADIUS * PLAYER_RADIUS) {
        return true;
      }
    }
    return false;
  }

