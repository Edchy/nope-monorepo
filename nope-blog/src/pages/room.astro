    const crown = new Mesh(
      new BoxGeometry(trimLength, CROWN_HEIGHT, CROWN_DEPTH),
      trimMaterial
    );
    crown.position.set(x, H - CROWN_HEIGHT / 2 - TRIM_CLEARANCE, z);
    crown.rotation.y = rotY;
    scene.add(crown);

    wallColliders.push(createWallCollider(x, z, w, rotY));
