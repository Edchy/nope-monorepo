---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

function mediaSrc(media: string | { src: string } | undefined) {
  return typeof media === "string" ? media : media?.src ?? "";
}

const workItems = (await getCollection("work")).map((item) => ({
  id: item.id.replace(/\/index$/, ""),
  title: item.data.title,
  description: item.data.description ?? "",
  type: item.data.type,
  images: (item.data.images ?? []).map((image) => mediaSrc(image)).filter(Boolean),
  effort: item.data.effort ?? 2,
  tags: item.data.tags,
  tech: item.data.tech,
  date: item.data.date,
  url: item.data.url ?? "",
}));

const effortSizes = {
  1: { width: 1.8, height: 1.35 },
  2: { width: 2.7, height: 1.95 },
  3: { width: 4.8, height: 3.3 },
};
type WallFacing = "positive" | "negative";

function wallSlot(
  x: number,
  z: number,
  rotY: number,
  wallLen: number,
  room: string,
  facing: WallFacing = "positive"
) {
  return { x, z, rotY, wallLen, room, facing };
}

function offsetAlongWall(
  slot: ReturnType<typeof wallSlot>,
  cycleIndex: number
) {
  if (cycleIndex === 0) return { x: slot.x, z: slot.z, scale: 1 };

  const lanePattern = [-0.24, 0.24, -0.4, 0.4];
  const lane = lanePattern[(cycleIndex - 1) % lanePattern.length] ?? 0;
  const offset = slot.wallLen * lane;
  const cos = Math.cos(slot.rotY);
  const sin = Math.sin(slot.rotY);

  return {
    x: slot.x + offset * cos,
    z: slot.z - offset * sin,
    scale: cycleIndex === 1 ? 0.88 : 0.8,
  };
}

const wallSlots = [
  // Main Hall (3 walls)
  wallSlot(0, 11.9, Math.PI, 12, "main-hall"),
  wallSlot(-5.9, 6, Math.PI / 2, 12, "main-hall"),
  wallSlot(5.9, 6, -Math.PI / 2, 12, "main-hall"),
  // Room A (3 walls)
  wallSlot(-4.9, -21, Math.PI / 2, 10, "room-a"),
  wallSlot(4.9, -21, -Math.PI / 2, 10, "room-a"),
  // Room B (3 walls)
  wallSlot(-8, -12.9, Math.PI, 12, "room-b", "negative"),
  wallSlot(-8, -3.1, 0, 12, "room-b", "negative"),
  wallSlot(-13.9, -8, Math.PI / 2, 10, "room-b"),
  // Room C (3 walls)
  wallSlot(8, -12.9, Math.PI, 12, "room-c", "negative"),
  wallSlot(8, -3.1, 0, 12, "room-c", "negative"),
  wallSlot(13.9, -8, -Math.PI / 2, 10, "room-c"),
  // Room D (3 walls)
  wallSlot(0, -35.9, 0, 10, "room-d"),
  wallSlot(-4.9, -31, Math.PI / 2, 10, "room-d"),
  wallSlot(4.9, -31, -Math.PI / 2, 10, "room-d"),
];

const roomsByOrder = ["main-hall", "room-a", "room-b", "room-c", "room-d"] as const;
const roomSlotsMap: Record<string, typeof wallSlots> = {};
for (const slot of wallSlots) {
  if (!roomSlotsMap[slot.room]) roomSlotsMap[slot.room] = [];
  roomSlotsMap[slot.room].push(slot);
}

const orderedSlots = roomsByOrder.flatMap((roomName) => roomSlotsMap[roomName]);
const ecommerceReservedSlot = roomSlotsMap["room-d"][0];
const availableSlots = orderedSlots.filter((slot) => slot !== ecommerceReservedSlot);

const ecommerceItem = workItems.find((item) => item.id === "ecommerce-platform");
const regularItems = workItems.filter((item) => item.id !== "ecommerce-platform");

const assignedItems = ecommerceItem
  ? [{ item: ecommerceItem, slot: ecommerceReservedSlot }]
  : [];

regularItems.forEach((item, index) => {
  const slotIndex = index % availableSlots.length;
  const cycleIndex = Math.floor(index / availableSlots.length);
  const slot = availableSlots[slotIndex];
  assignedItems.push({ item, slot, cycleIndex });
});

type DisplayKind = "wall-panel" | "wall-monitor" | "crt-stack";
type DisplayMediaKind = "image" | "slideshow";

function getDisplayKind(room: string, index: number): DisplayKind {
  if (room === "main-hall" || room === "room-d") return "wall-panel";
  if (room === "room-a") return "wall-monitor";
  return index % 2 === 0 ? "crt-stack" : "wall-monitor";
}

function getDisplayMedia(item: typeof workItems[number]) {
  if (item.images.length > 0) {
    return {
      mediaKind: item.images.length > 1 ? "slideshow" as const : "image" as const,
      image: item.images[0] || "",
      images: item.images,
    };
  }

  return {
    mediaKind: "image" as const,
    image: "",
    images: [],
  };
}

const displayData = assignedItems.map(({ item, slot, cycleIndex = 0 }, index) => {
  const baseSize = effortSizes[item.effort as keyof typeof effortSizes] ?? effortSizes[2];
  const kind = getDisplayKind(slot.room, index);
  const media = getDisplayMedia(item);
  const placement = offsetAlongWall(slot, cycleIndex);
  const repeatScale = placement.scale;
  const size =
    kind === "wall-panel"
      ? { width: baseSize.width * repeatScale, height: baseSize.height * repeatScale }
      : kind === "wall-monitor"
        ? {
            width: Math.max(baseSize.width * 0.82 * repeatScale, 1.45),
            height: Math.max(baseSize.height * 0.8 * repeatScale, 1.05),
          }
        : {
            width: Math.max(baseSize.width * 0.72 * repeatScale, 1.3),
            height: Math.max(baseSize.height * 0.7 * repeatScale, 0.95),
          };
  return {
    title: item.title,
    description: item.description,
    image: media.image,
    images: media.images,
    mediaKind: media.mediaKind,
    effort: item.effort,
    tags: item.tags,
    tech: item.tech,
    date: item.date instanceof Date ? item.date.toISOString() : String(item.date),
    kind,
    room: slot.room,
    width: size.width,
    height: size.height,
    x: placement.x,
    z: placement.z,
    rotY: slot.rotY,
    facing: slot.facing,
    url: item.url,
  };
});

const displayDataJson = JSON.stringify(displayData);
---

<BaseLayout title="Room" noFooter>
  <div class="gallery-wrapper" id="gallery-wrapper" data-gallery-state="idle">
    <canvas id="gallery-canvas"></canvas>
    <div class="gallery-hud">
      <div class="gallery-hud__panel">
        <p class="gallery-hud__status" id="gallery-status" aria-live="polite" hidden>
          Paused.
        </p>
        <p class="gallery-hud__instructions">
          <span class="gallery-kbd-group"><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd></span>
          move · Mouse look · <kbd>E</kbd> open
        </p>
      </div>
    </div>
    <div id="display-labels"></div>
    <div class="gallery-overlay" id="gallery-overlay">
      <h1>Digital Gallery</h1>
      <p>Walk the exhibition at your own pace.</p>
      <button type="button" class="gallery-overlay__action" id="gallery-toggle">
        Enter
      </button>
    </div>
  </div>
  <div id="gallery-mobile-wall" hidden>
    <p>The 3D gallery requires a desktop browser.</p>
  </div>
  <script type="application/json" id="gallery-data" set:html={displayDataJson} />
</BaseLayout>

<style is:global>
  .gallery-wrapper {
    position: fixed;
    inset: 0;
    z-index: 0;
    --gallery-chrome-surface: color-mix(in oklch, var(--neutral-950) 78%, transparent);
    --gallery-chrome-border: color-mix(in oklch, var(--neutral-50) 20%, transparent);
    --gallery-chrome-text: var(--neutral-50);
    --gallery-chrome-text-muted: color-mix(in oklch, var(--neutral-50) 76%, transparent);
  }

  #gallery-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .gallery-hud {
    position: absolute;
    inset-block-start: var(--space-4);
    inset-inline: var(--space-4);
    z-index: 3;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    pointer-events: none;
  }

  .gallery-hud > * {
    pointer-events: auto;
  }

  .gallery-overlay__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding-inline: var(--space-4);
    border: var(--border-width-1) solid var(--gallery-chrome-border);
    background: var(--gallery-chrome-surface);
    backdrop-filter: blur(18px) saturate(145%);
    -webkit-backdrop-filter: blur(18px) saturate(145%);
    color: var(--gallery-chrome-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .gallery-overlay__action:hover {
    background: color-mix(in oklch, var(--neutral-950) 88%, var(--neutral-50));
    color: var(--gallery-chrome-text);
    text-decoration: none;
  }

  .gallery-hud__panel {
    width: min(100%, 30rem);
    margin-inline-start: auto;
    padding: var(--space-6);
    border: var(--border-width-1) solid var(--gallery-chrome-border);
    background: var(--gallery-chrome-surface);
    backdrop-filter: blur(18px) saturate(145%);
    -webkit-backdrop-filter: blur(18px) saturate(145%);
    display: grid;
    gap: var(--space-3);
  }

  .gallery-hud__status {
    color: var(--gallery-chrome-text);
    font-size: var(--font-size-base);
    line-height: var(--line-height-snug);
    max-width: 32ch;
  }

  .gallery-hud__instructions {
    color: var(--gallery-chrome-text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    max-width: 40ch;
    padding-top: var(--space-2);
  }

  .gallery-hud kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.1em;
    min-height: 2.1em;
    padding-inline: 0.55em;
    border: var(--border-width-1) solid color-mix(in oklch, var(--neutral-50) 28%, transparent);
    background: color-mix(in oklch, var(--neutral-50) 10%, transparent);
    color: var(--gallery-chrome-text);
    font-family: inherit;
    font-size: 0.8em;
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    vertical-align: middle;
    box-shadow: inset 0 -2px 0 color-mix(in oklch, var(--neutral-950) 45%, transparent);
  }

  .gallery-kbd-group {
    display: inline-flex;
    gap: var(--space-1);
    margin-inline-end: var(--space-1);
    vertical-align: middle;
  }

  .gallery-wrapper[data-gallery-state="locked"] .gallery-hud {
    justify-content: flex-end;
  }

  .gallery-wrapper[data-gallery-state="locked"] .gallery-hud__instructions {
    display: none;
  }

  .gallery-wrapper[data-gallery-state="locked"] .gallery-hud__panel {
    width: auto;
    max-width: min(100%, 18rem);
    padding: var(--space-3) var(--space-4);
    gap: 0;
  }

  .gallery-wrapper[data-gallery-state="locked"] .gallery-hud__status {
    max-width: none;
    font-size: var(--font-size-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 767px) {
    .gallery-hud {
      flex-direction: column;
      align-items: stretch;
      inset-inline: var(--space-4);
    }

    .gallery-hud__panel {
      width: 100%;
      margin-inline-start: 0;
    }

    .gallery-hud__status {
      max-width: none;
    }
  }

  #display-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    display: none;
  }

  #display-labels.active {
    display: block;
  }

  .display-label {
    position: absolute;
    left: 0;
    top: 0;
    width: min(460px, calc(100vw - 32px));
    padding: 26px 28px 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0.08)),
      linear-gradient(180deg, rgba(33, 38, 48, 0.7), rgba(18, 22, 30, 0.58));
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.26),
      inset 0 -1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(18px) saturate(145%);
    -webkit-backdrop-filter: blur(18px) saturate(145%);
    color: #f6f7fb;
    font-size: 1.04rem;
    line-height: 1.55;
    transform: translate(calc(-100% + 18px), calc(-100% + 18px)) scale(0.94);
    opacity: 0;
    transition: opacity 0.36s ease, transform 0.36s ease;
    pointer-events: none;
  }

  .display-label.visible {
    opacity: 1;
    transform: translate(-100%, -100%) scale(1);
  }

  .display-label-accent {
    display: block;
    width: 52px;
    height: 5px;
    border-radius: 999px;
    margin-bottom: 14px;
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.22);
  }

  .display-label-title {
    font-size: 1.36rem;
    font-weight: 650;
    display: block;
    margin-bottom: 8px;
    color: #fbfcff;
    letter-spacing: -0.02em;
  }

  .display-label-meta {
    color: rgba(246, 247, 251, 0.58);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  .display-label-desc {
    color: rgba(246, 247, 251, 0.8);
    font-size: 1rem;
    line-height: 1.6;
    display: block;
  }
  .display-label-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 14px;
  }
  .display-label-tech-tag {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(246, 247, 251, 0.7);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 6px;
    padding: 3px 8px;
  }
  .display-label-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 14px;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(246, 247, 251, 0.7);
  }
  .display-label-link kbd {
    font-family: inherit;
    font-size: 0.72rem;
    color: #f4f4f5;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 5px;
    padding: 2px 7px;
    letter-spacing: 0;
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 45%),
      linear-gradient(180deg, rgba(19, 21, 24, 0.88), rgba(11, 12, 14, 0.94));
    transition: opacity 0.4s;
  }

  .gallery-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .gallery-overlay h1 {
    font-family: var(--font-nature), system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    color: #f7f3eb;
    margin: 0;
  }

  .gallery-overlay p {
    font-family: var(--font-nature), system-ui, sans-serif;
    font-weight: var(--font-weight-regular);
    color: rgba(247, 243, 235, 0.78);
    font-size: 1rem;
    margin: 0;
  }

  .gallery-overlay__action {
  }

  #gallery-mobile-wall {
    --gallery-chrome-surface: color-mix(in oklch, var(--neutral-950) 78%, transparent);
    --gallery-chrome-border: color-mix(in oklch, var(--neutral-50) 20%, transparent);
    --gallery-chrome-text: var(--neutral-50);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    min-height: 100dvh;
    padding: var(--space-6);
    text-align: center;
    color: var(--neutral-50);
    background: var(--neutral-950);
  }

  #gallery-mobile-wall p {
    font-size: var(--font-size-lg);
    color: var(--neutral-400);
    margin: 0;
  }
</style>

<script>
  import type { Group, MeshBasicMaterial, Side, Texture, Vector3 } from 'three';

  type WallFacing = 'positive' | 'negative';
  type DisplayKind = 'wall-panel' | 'wall-monitor' | 'crt-stack';
  type DisplayMediaKind = 'image' | 'slideshow';

  async function init() {
  const {
    ACESFilmicToneMapping,
    BoxGeometry,
    CanvasTexture,
    CatmullRomCurve3,
    Color,
    DirectionalLight,
    DoubleSide,
    Euler,
    Fog,
    Group,
    HemisphereLight,
    Mesh,
    MeshBasicMaterial,
    MeshStandardMaterial,
    NoColorSpace,
    Object3D,
    PerspectiveCamera,
    PlaneGeometry,
    RepeatWrapping,
    Scene,
    SpotLight,
    SRGBColorSpace,
    Texture,
    TextureLoader,
    TubeGeometry,
    Vector3,
    WebGLRenderer,
  } = await import('three');
  const { PointerLockControls } = await import('three/addons/controls/PointerLockControls.js');
  const displayData = JSON.parse(document.getElementById('gallery-data')?.textContent || '[]');

  const canvas = document.getElementById('gallery-canvas') as HTMLCanvasElement;
  const overlay = document.getElementById('gallery-overlay') as HTMLElement;
  const wrapper = document.getElementById('gallery-wrapper') as HTMLElement;
  const statusText = document.getElementById('gallery-status') as HTMLParagraphElement;
  const toggleButton = document.getElementById('gallery-toggle') as HTMLButtonElement;
  if (!canvas || !overlay || !wrapper || !statusText || !toggleButton) return;

  let hasExplored = false;
  const initialStatusHtml = '';
  const pausedStatusHtml = 'Paused.';
  const exploringStatusHtml = 'Exploring. <kbd>Esc</kbd> to pause.';

  function syncGalleryChrome(locked: boolean) {
    wrapper.dataset.galleryState = locked ? 'locked' : 'idle';

    if (locked) {
      statusText.innerHTML = exploringStatusHtml;
      statusText.hidden = false;
      toggleButton.textContent = 'Exploring';
      return;
    }

    const statusHtml = hasExplored ? pausedStatusHtml : initialStatusHtml;
    statusText.innerHTML = statusHtml;
    statusText.hidden = statusHtml.length === 0;
    toggleButton.textContent = hasExplored ? 'Resume' : 'Enter';
  }

  syncGalleryChrome(false);

  // Scene
  const scene = new Scene();
  scene.background = new Color(0x111417);
  scene.fog = new Fog(0x111417, 16, 45);

  // Camera
  const camera = new PerspectiveCamera(70, 1, 0.1, 100);
  camera.position.set(0, 1.7, 6);

  // Renderer
  const renderer = new WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
  renderer.outputColorSpace = SRGBColorSpace;
  renderer.toneMapping = ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1;
  renderer.shadowMap.enabled = false;
  const maxAnisotropy = Math.min(renderer.capabilities.getMaxAnisotropy(), 2);
  const textureLoader = new TextureLoader();
  textureLoader.setCrossOrigin('anonymous');

  function resize() {
    const w = window.innerWidth;
    const h = window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  }
  resize();
  window.addEventListener('resize', resize);

  // Lighting
  const hemisphereLight = new HemisphereLight(0xf3eee3, 0x2b2a28, 0.55);
  scene.add(hemisphereLight);

  const fillLight = new DirectionalLight(0xcdd8e5, 1.35);
  fillLight.position.set(8, 11, 6);
  scene.add(fillLight);

  const backLight = new DirectionalLight(0xfff2d8, 0.42);
  backLight.position.set(-10, 7, -6);
  scene.add(backLight);

  // Room height
  const H = 7;

  function canvasTexture(
    size: number,
    draw: (ctx: CanvasRenderingContext2D, size: number) => void
  ) {
    const canvas = document.createElement('canvas');
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('Unable to create texture context');
    draw(ctx, size);
    const texture = new CanvasTexture(canvas);
    texture.colorSpace = SRGBColorSpace;
    texture.wrapS = RepeatWrapping;
    texture.wrapT = RepeatWrapping;
    texture.anisotropy = maxAnisotropy;
    return texture;
  }

  function monochromeTexture(
    size: number,
    draw: (ctx: CanvasRenderingContext2D, size: number) => void
  ) {
    const texture = canvasTexture(size, draw);
    texture.colorSpace = NoColorSpace;
    return texture;
  }

  function fillNoise(
    ctx: CanvasRenderingContext2D,
    size: number,
    count: number,
    gray: [number, number],
    alpha: [number, number],
    maxRadius: number
  ) {
    for (let i = 0; i < count; i += 1) {
      const x = Math.random() * size;
      const y = Math.random() * size;
      const radius = Math.random() * maxRadius + 0.35;
      const tone = Math.round(gray[0] + Math.random() * (gray[1] - gray[0]));
      ctx.fillStyle = `rgba(${tone}, ${tone}, ${tone}, ${alpha[0] + Math.random() * (alpha[1] - alpha[0])})`;
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  interface MaterialRecipe {
    map: Texture;
    roughnessMap?: Texture;
    bumpMap?: Texture;
    color?: number;
    roughness: number;
    metalness: number;
    bumpScale?: number;
    side?: Side;
  }

  function buildMaterial(recipe: MaterialRecipe) {
    return new MeshStandardMaterial({
      color: recipe.color ?? 0xffffff,
      map: recipe.map,
      roughnessMap: recipe.roughnessMap,
      bumpMap: recipe.bumpMap,
      roughness: recipe.roughness,
      metalness: recipe.metalness,
      bumpScale: recipe.bumpScale ?? 0,
      side: recipe.side,
    });
  }

  const floorColorTexture = canvasTexture(256, (ctx, size) => {
    const gradient = ctx.createLinearGradient(0, 0, size, size);
    gradient.addColorStop(0, '#4e5358');
    gradient.addColorStop(1, '#34383c');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, size, size);
    fillNoise(ctx, size, 4200, [58, 112], [0.03, 0.1], 1.4);
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    ctx.lineWidth = size * 0.0035;
    for (let i = 1; i < 4; i += 1) {
      const offset = (size / 4) * i;
      ctx.beginPath();
      ctx.moveTo(offset, 0);
      ctx.lineTo(offset, size);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(0, offset);
      ctx.lineTo(size, offset);
      ctx.stroke();
    }
  });

  const floorRoughnessTexture = monochromeTexture(256, (ctx, size) => {
    ctx.fillStyle = '#d7d7d7';
    ctx.fillRect(0, 0, size, size);
    fillNoise(ctx, size, 5000, [140, 245], [0.02, 0.08], 1.2);
  });

