  function addWall(x: number, z: number, w: number, rotY: number) {
    const mesh = new Mesh(
      new BoxGeometry(w, H, WALL_THICKNESS),
      wallMaterial
    );
    mesh.position.set(x, H / 2, z);
    mesh.rotation.y = rotY;
