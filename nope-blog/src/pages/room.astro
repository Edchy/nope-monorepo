    const trimLength = Math.max(w - TRIM_END_INSET * 2, 0.2);

    const baseboard = new Mesh(
      new BoxGeometry(trimLength, BASEBOARD_HEIGHT, BASEBOARD_DEPTH),
      trimMaterial
