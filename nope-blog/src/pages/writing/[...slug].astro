---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  prev: CollectionEntry<'blog'> | null;
  next: CollectionEntry<'blog'> | null;
}

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  const toSlug = (id: string) => id.replace(/\/index\.md$/, '').replace(/\.md$/, '');
  return posts.map((post, i) => ({
    params: { slug: toSlug(post.id) },
    props: {
      post,
      prev: posts[i + 1] ?? null,
      next: posts[i - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
  tags={post.data.tags}
  author={post.data.author}
  postId={post.id}
  prev={prev ? { title: prev.data.title, href: `/writing/${prev.id.replace(/\/index\.md$/, '').replace(/\.md$/, '')}` } : null}
  next={next ? { title: next.data.title, href: `/writing/${next.id.replace(/\/index\.md$/, '').replace(/\.md$/, '')}` } : null}
>
  <Content />
</BlogLayout>
