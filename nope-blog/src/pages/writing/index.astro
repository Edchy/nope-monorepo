---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const getVariant = (i: number) => i % 2 === 0 ? "cell--light" : "cell--dark";
---

<BaseLayout title="Writing — NOPE" description="Notes on building, design, and the web.">
  <div class="writing-grid">
    {posts.map((post, i) => (
      <a
        href={`/writing/${post.id.replace(/\/index\.md$/, "").replace(/\.md$/, "")}`}
        class={`cell cell--lift ${getVariant(i)}`}
        data-lift-max="18"
      >
        <div class="cell__top">
          <p class="cell__eyebrow cell__meta">
            {post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
            })}
          </p>
          <h2 class="cell__title" transition:name={`post-title-${post.id}`}>{post.data.title}</h2>
        </div>
        {post.data.description && (
          <p class="cell__desc cell__meta">{post.data.description}</p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .writing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 40svh;
    min-height: 100svh;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-4) var(--space-4) 2rem;
  }

  /* ── Base cell (mirrors index.astro) ── */
  .cell {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    border: none;
    text-transform: uppercase;
  }

  .cell--lift {
    --_tx: 0px;
    --_ty: 0px;
    --_scale: 1;
    transform: translate(var(--_tx), var(--_ty)) scale(var(--_scale));
    transform-origin: center;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  /* ── Variants ── */
  .cell--light {
    background: var(--color-background);
    color: var(--color-text-primary);
    border: var(--border-width-1) solid var(--color-border-default);
  }

  .cell--dark {
    background: var(--neutral-900);
    color: var(--neutral-50);
    border: var(--border-width-1) solid var(--neutral-900);
  }

  /* ── Typography (mirrors index.astro) ── */
  .cell__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cell__eyebrow {
    margin: 0;
  }

  .cell__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .cell__desc {
    margin: 0;
    line-height: var(--line-height-relaxed);
    text-transform: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cell__meta {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    line-height: var(--line-height-relaxed);
    color: currentColor;
    opacity: 0.62;
  }

  .cell__eyebrow {
    color: var(--brand-green);
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .writing-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 44vw;
    }
  }

  @media (max-width: 480px) {
    .writing-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: minmax(14rem, auto);
      min-height: auto;
      gap: 0;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .cell--lift:is(:hover, :focus-visible) {
      z-index: 2;
    }
  }

  @media (max-width: 768px) {
    .cell--lift {
      transform: none;
      transition: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cell--lift {
      transition: none;
    }
  }
</style>

<script>
  {
    let cleanup: (() => void) | undefined;

    const canUseLift = () =>
      window.matchMedia("(min-width: 769px)").matches &&
      window.matchMedia("(hover: hover) and (pointer: fine)").matches &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const reset = (cell: HTMLElement) => {
      cell.style.setProperty("--_tx", "0px");
      cell.style.setProperty("--_ty", "0px");
      cell.style.setProperty("--_scale", "1");
    };

    function init() {
      cleanup?.();

      const cells = document.querySelectorAll<HTMLElement>(".writing-grid .cell--lift");
      if (!cells.length || !canUseLift()) {
        cells.forEach(reset);
        cleanup = undefined;
        return;
      }

      const controller = new AbortController();
      const { signal } = controller;

      cells.forEach((cell) => {
        const max = Number(cell.dataset.liftMax ?? 18);

        cell.addEventListener("mousemove", (e) => {
          const rect = cell.getBoundingClientRect();
          const nx = (e.clientX - rect.left) / rect.width;
          const ny = (e.clientY - rect.top) / rect.height;
          cell.style.setProperty("--_tx", `${nx * max}px`);
          cell.style.setProperty("--_ty", `${-(ny * max)}px`);
          cell.style.setProperty("--_scale", "1.04");
        }, { signal });

        cell.addEventListener("mouseleave", () => reset(cell), { signal });
      });

      cleanup = () => {
        controller.abort();
        cells.forEach(reset);
      };
    }

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-swap", () => cleanup?.(), { once: true });
    init();
  }
</script>
