---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentPosts = posts.slice(0, 6);
const olderPosts = posts.slice(6);

const getVariant = (i: number) => i % 2 === 0 ? "cell--light" : "cell--dark";

function postHref(id: string) {
  return `/writing/${id.replace(/\/index\.md$/, "").replace(/\.md$/, "")}`;
}
---

<BaseLayout title="Writing — NOPE" description="Notes on building, design, and the web.">
  <div class="writing-page">

    <header class="writing-header">
      <p class="writing-intro">
        A place for scribbles and notes — mostly so I can revisit things I find interesting,
        instead of leaving them to rot in my phone's notes app. If something here is useful
        to you too, that's a bonus.
      </p>
    </header>

    <h3 class="section-heading">Recent posts</h3>
    <div class="writing-grid">
      {recentPosts.map((post, i) => (
        <a
          href={postHref(post.id)}
          class={`cell cell--lift ${getVariant(i)}`}
          data-lift-max="14"
        >
          <div class="cell__top">
            <p class="cell__eyebrow cell__meta">
              {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
              })}
            </p>
            <h2 class="cell__title" transition:name={`post-title-${post.id}`}>{post.data.title}</h2>
          </div>
          {post.data.description && (
            <p class="cell__desc cell__meta">{post.data.description}</p>
          )}
        </a>
      ))}
    </div>

    {olderPosts.length > 0 && (
      <section class="older-posts">
        <h3 class="older-posts__heading">Older posts</h3>
        <ul class="older-posts__list">
          {olderPosts.map((post) => (
            <li>
              <a href={postHref(post.id)} class="older-posts__link">
                <span class="older-posts__title">{post.data.title}</span>
                <span class="older-posts__leader" aria-hidden="true"></span>
                <span class="older-posts__date">
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                  })}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .writing-page {
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    background: var(--2);
    color: var(--3);
  }

  /* ── Header ── */
  .writing-header {
    padding: var(--space-10) var(--space-8) var(--space-6);
  }

  .writing-intro {
    margin: 0;
    padding: var(--space-6);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    text-transform: none;
    max-width: 52ch;
    opacity: 0.55;
    letter-spacing: 0;
  }

  /* ── Section headings ── */
  .section-heading {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.4;
    margin: 0;
    padding: var(--space-6) var(--space-6) var(--space-4);
  }

  /* ── Cards grid ── */
  .writing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: clamp(220px, 36svh, 340px);
    gap: 0;
  }

  /* ── Base cell ── */
  .cell {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    text-transform: uppercase;
    border: var(--border-width-1) solid color-mix(in oklch, var(--3) 30%, var(--2));
    margin: -1px 0 0 -1px;
  }

  .cell--lift {
    --_tx: 0px;
    --_ty: 0px;
    --_scale: 1;
    transform: translate(var(--_tx), var(--_ty)) scale(var(--_scale));
    transform-origin: center;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  .cell--light {
    background: var(--3);
    color: var(--2);
    border-color: var(--3);
  }

  .cell--dark {
    background: var(--2);
    color: var(--3);
    border-color: var(--2);
  }

  .cell__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cell__eyebrow {
    margin: 0;
    color: currentColor;
    opacity: 1;
  }

  .cell__title {
    margin: 0;
    font-family: var(--font-zt-nature);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .cell__desc {
    margin: 0;
    line-height: var(--line-height-relaxed);
    text-transform: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cell__meta {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    line-height: var(--line-height-relaxed);
    color: currentColor;
    opacity: 0.62;
  }

  /* ── Older posts ── */
  .older-posts {
    padding: var(--space-6) var(--space-6) var(--space-12);
  }

  .older-posts__heading {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.4;
    margin: 0 0 var(--space-4);
  }

  .older-posts__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .older-posts__link {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    color: inherit;
    text-transform: uppercase;
    transition: opacity 0.12s ease;
  }

  .older-posts__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .older-posts__leader {
    flex: 1;
    border-bottom: var(--border-width-1) dashed color-mix(in oklch, var(--3) 35%, var(--2));
    margin: 0 var(--space-3) 0.2em;
  }

  .older-posts__date {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    opacity: 0.5;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Interactions ── */
  @media (hover: hover) and (pointer: fine) {
    .older-posts__link:hover {
      opacity: 0.5;
    }

    .cell--lift:is(:hover, :focus-visible) {
      z-index: 2;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .writing-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .writing-header {
      padding: var(--space-8) var(--space-6) var(--space-5);
    }

    .older-posts {
      padding: var(--space-8) var(--space-6) var(--space-10);
    }
  }

  @media (max-width: 768px) {
    .cell--lift {
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 480px) {
    .writing-grid {
      grid-template-columns: 1fr;
    }

    .writing-grid .cell {
      padding: var(--space-8) var(--space-6);
    }

    .writing-header {
      padding: var(--space-6) var(--space-8) var(--space-5);
    }

    .writing-intro {
      max-width: 100%;
    }

.older-posts {
      padding: var(--space-6) var(--space-4) var(--space-8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cell--lift {
      transition: none;
    }
  }
</style>

<script>
  {
    let cleanup: (() => void) | undefined;

    const canUseLift = () =>
      window.matchMedia("(min-width: 769px)").matches &&
      window.matchMedia("(hover: hover) and (pointer: fine)").matches &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const reset = (cell: HTMLElement) => {
      cell.style.setProperty("--_tx", "0px");
      cell.style.setProperty("--_ty", "0px");
      cell.style.setProperty("--_scale", "1");
    };

    function init() {
      cleanup?.();

      const cells = document.querySelectorAll<HTMLElement>(".writing-grid .cell--lift");
      if (!cells.length || !canUseLift()) {
        cells.forEach(reset);
        cleanup = undefined;
        return;
      }

      const controller = new AbortController();
      const { signal } = controller;

      cells.forEach((cell) => {
        const max = Number(cell.dataset.liftMax ?? 14);

        cell.addEventListener("mousemove", (e) => {
          const rect = cell.getBoundingClientRect();
          const nx = (e.clientX - rect.left) / rect.width;
          const ny = (e.clientY - rect.top) / rect.height;
          cell.style.setProperty("--_tx", `${nx * max}px`);
          cell.style.setProperty("--_ty", `${-(ny * max)}px`);
          cell.style.setProperty("--_scale", "1.04");
        }, { signal });

        cell.addEventListener("mouseleave", () => reset(cell), { signal });
      });

      cleanup = () => {
        controller.abort();
        cells.forEach(reset);
      };
    }

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-swap", () => cleanup?.(), { once: true });
    init();
  }
</script>
