---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const [featured, ...rest] = posts;

function postHref(id: string) {
  return `/writing/${id.replace(/\/index\.md$/, "").replace(/\.md$/, "")}`;
}

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short" });

// Group tags into topic families, each with its own pastel chip color.
const TAG_FAMILY: Record<string, string> = {
  ai: "ai",
  agents: "ai",
  llm: "ai",
  models: "ai",
  mcp: "ai",
  prompting: "ai",
  "local-models": "ai",
  "claude-code": "ai",
  ecosystem: "ai",
  fundamentals: "ai",
  tools: "tools",
  cli: "tools",
  workflow: "tools",
  building: "tools",
  dev: "code",
  js: "code",
  git: "code",
  technical: "code",
  nerdstuff: "code",
  css: "design",
  design: "design",
  ux: "design",
  life: "life",
  history: "life",
};

const tagFamily = (tag: string) => TAG_FAMILY[tag] ?? "default";

// Unique topic families for each post, used for filtering.
const postFamilies = (tags: string[]) => [...new Set(tags.map(tagFamily))];

// Display order + labels for the filter chips. Only families that actually
// appear on a non-featured post get a chip.
const FAMILY_LABELS: Record<string, string> = {
  ai: "ai",
  tools: "tools",
  code: "code",
  design: "design",
  life: "life",
  default: "misc",
};
const FAMILY_ORDER = ["ai", "tools", "code", "design", "life", "default"];

const availableFamilies = FAMILY_ORDER.filter((fam) =>
  rest.some((post) => postFamilies(post.data.tags).includes(fam))
);

// Each family's hue (matches the pastel chip colors) as RGB triplets so we can
// vary the alpha in the radial glow.
const FAMILY_RGB: Record<string, string> = {
  ai: "139, 92, 246", // violet
  tools: "34, 197, 94", // green
  code: "56, 189, 248", // sky
  design: "236, 72, 153", // pink
  life: "245, 158, 11", // amber
  default: "100, 116, 139", // slate
};

// Build the "sphere grid" backdrop for a card on a white surface: a fine grid
// plus a soft radial glow centered low, tinted by the card's primary family.
function auroraFor(families: string[]) {
  const primary = FAMILY_RGB[families[0]] ?? FAMILY_RGB.default;
  return [
    "linear-gradient(to right, rgba(71,85,105,0.08) 1px, transparent 1px)",
    "linear-gradient(to bottom, rgba(71,85,105,0.08) 1px, transparent 1px)",
    `radial-gradient(circle at 50% 85%, rgba(${primary}, 0.14) 0%, rgba(${primary}, 0.05) 45%, transparent 80%)`,
  ].join(", ");
}
---

<BaseLayout title="Writing — NOPE" description="Notes on building, design, and the web.">
  <div class="writing">
    <div class="container">
      <header class="writing__header">
        <h1 class="writing__title">Writing</h1>
        <p class="writing__intro">
          A place for scribbles and notes, mostly so I can revisit things I find
          interesting, instead of leaving them to rot in my phone's notes app. If
          something here is useful to you too, that's a bonus.
        </p>
      </header>

      {featured && (
        <a href={postHref(featured.id)} class="featured">
          <span class="card__top featured__top">
            <span class="featured__eyebrow">
              Latest ·{" "}
              <time datetime={featured.data.date.toISOString()}>
                {fmtDate(featured.data.date)}
              </time>
            </span>
            {featured.data.tags.length > 0 && (
              <span class="card__tags">
                {featured.data.tags.slice(0, 4).map((tag) => (
                  <span class={`card__tag card__tag--${tagFamily(tag)}`}>{tag}</span>
                ))}
              </span>
            )}
          </span>
          <h2
            class="featured__title"
            transition:name={`post-title-${featured.id}`}
          >{featured.data.title}</h2>
          {featured.data.description && (
            <p class="featured__desc">{featured.data.description}</p>
          )}
          <span class="featured__cue" aria-hidden="true">Read →</span>
        </a>
      )}

      {availableFamilies.length > 1 && (
        <div class="filters" role="group" aria-label="Filter posts by topic">
          <button type="button" class="filter is-active" data-filter="all" aria-pressed="true">All</button>
          {availableFamilies.map((fam) => (
            <button
              type="button"
              class={`filter filter--${fam}`}
              data-filter={fam}
              aria-pressed="false"
            >{FAMILY_LABELS[fam]}</button>
          ))}
        </div>
      )}

      {rest.length > 0 && (
        <ul class="grid">
          {rest.map((post) => (
            <li data-families={postFamilies(post.data.tags).join(" ")}>
              <a
                href={postHref(post.id)}
                class="card"
                style={`--aurora: ${auroraFor(postFamilies(post.data.tags))}`}
              >
                <span class="card__top">
                  <time
                    class="card__date"
                    datetime={post.data.date.toISOString()}
                  >{fmtDate(post.data.date)}</time>
                  {post.data.tags.length > 0 && (
                    <span class="card__tags">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class={`card__tag card__tag--${tagFamily(tag)}`}>{tag}</span>
                      ))}
                    </span>
                  )}
                </span>
                <span
                  class="card__title"
                  transition:name={`post-title-${post.id}`}
                >{post.data.title}</span>
                {post.data.description && (
                  <span class="card__desc">{post.data.description}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}

      <p class="grid__empty" hidden>Nothing here under that topic yet.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .writing {
    flex: 1;
    background: var(--2);
    color: var(--3);
    padding-block: clamp(2rem, 6vw, 4rem) clamp(4rem, 10vw, 7rem);
  }

  .container {
    max-width: var(--max-width-site);
    margin-inline: auto;
    padding-inline: var(--space-container);
  }

  /* ── Header ── */
  .writing__header {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
    max-width: var(--max-width-content);
  }

  .writing__title {
    font-family: var(--font-zt-nature);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: var(--font-weight-black);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .writing__intro {
    margin: clamp(1rem, 2.5vw, 1.5rem) 0 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  /* ── Filters ── */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: clamp(3rem, 8vw, 5rem);
    margin-bottom: clamp(1rem, 2.5vw, 1.5rem);
  }

  .filter {
    font-family: inherit;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    padding: 0.4em 0.9em;
    border: var(--border-width-1) solid var(--color-border-default);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .filter:hover {
    color: var(--3);
    border-color: var(--3);
  }

  .filter.is-active {
    background: var(--chip-bg, var(--3));
    color: var(--chip-fg, var(--2));
    border-color: var(--chip-bg, var(--3));
  }

  /* Active chip adopts its family pastel */
  .filter--ai.is-active { --chip-bg: #e7e0fb; --chip-fg: #5b4b8a; }
  .filter--tools.is-active { --chip-bg: #dcefe6; --chip-fg: #3f7a5d; }
  .filter--code.is-active { --chip-bg: #dceafb; --chip-fg: #41658f; }
  .filter--design.is-active { --chip-bg: #fbe2ec; --chip-fg: #97527a; }
  .filter--life.is-active { --chip-bg: #fdeecf; --chip-fg: #8a6a36; }

  .filter:focus-visible {
    outline: 2px solid var(--3);
    outline-offset: 2px;
  }

  .grid__empty {
    margin: clamp(2rem, 5vw, 3rem) 0 0;
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
  }

  /* ── Featured ── */
  .featured {
    display: block;
    background: #000;
    color: #fff;
    padding: clamp(2rem, 5vw, 3.5rem);
    text-decoration: none;
    transition: transform 0.25s var(--motion-ease-decelerate);
  }

  .featured__top {
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .featured__eyebrow {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in oklch, #fff 55%, #000);
    white-space: nowrap;
  }

  .featured__title {
    font-family: var(--font-zt-nature);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: var(--font-weight-black);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin: 0;
    text-wrap: balance;
    max-width: 18ch;
  }

  .featured__desc {
    margin: clamp(1rem, 2.5vw, 1.5rem) 0 0;
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: color-mix(in oklch, #fff 70%, #000);
    max-width: 56ch;
    text-wrap: pretty;
  }

  .featured__cue {
    display: inline-block;
    margin-top: clamp(1.75rem, 4vw, 2.5rem);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in oklch, #fff 60%, #000);
    transition: transform 0.2s var(--motion-ease-decelerate);
  }

  /* ── Grid ── */
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }

  .card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 13rem;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border: var(--border-width-1) solid var(--color-border-default);
    text-decoration: none;
    color: var(--3);
    background: #fff;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  /* Per-card sphere-grid backdrop, glow tinted by its topic family color */
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: var(--aurora, none);
    background-size: 32px 32px, 32px 32px, 100% 100%;
    opacity: 0.75;
    transition: opacity 0.25s ease;
  }

  .card > * {
    position: relative;
  }

  .card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .card__date {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .card__title {
    font-family: var(--font-zt-nature);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-snug);
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .card__desc {
    margin-top: var(--space-2);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Tags ── */
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--space-2);
  }

  .card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.25em 0.55em;
    /* Square pills — no radius to match the page */
    border-radius: 0;
    white-space: nowrap;
    /* Pastel defaults; families override below */
    background: var(--tag-bg, #ececec);
    color: var(--tag-fg, #555);
  }

  /* ── Pastel topic families (soft, low-chroma) ── */
  .card__tag--ai {
    --tag-bg: #e7e0fb; /* lavender */
    --tag-fg: #5b4b8a;
  }
  .card__tag--tools {
    --tag-bg: #dcefe6; /* mint */
    --tag-fg: #3f7a5d;
  }
  .card__tag--code {
    --tag-bg: #dceafb; /* sky */
    --tag-fg: #41658f;
  }
  .card__tag--design {
    --tag-bg: #fbe2ec; /* rose */
    --tag-fg: #97527a;
  }
  .card__tag--life {
    --tag-bg: #fdeecf; /* sand */
    --tag-fg: #8a6a36;
  }
  .card__tag--default {
    --tag-bg: #ececec;
    --tag-fg: #5a5a5a;
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Hover (pointer devices only) ── */
  @media (hover: hover) and (pointer: fine) {
    .featured:hover .featured__cue {
      transform: translateX(3px);
    }

    .card:hover {
      border-color: var(--3);
      transform: translateY(-2px);
    }

    .card:hover::before {
      opacity: 1;
    }
  }
</style>

<script>
  {
    let cleanup: (() => void) | undefined;

    function init() {
      cleanup?.();

      const filters = Array.from(
        document.querySelectorAll<HTMLButtonElement>(".filter"),
      );
      if (filters.length === 0) return;

      const items = Array.from(
        document.querySelectorAll<HTMLLIElement>(".grid > li"),
      );
      const empty = document.querySelector<HTMLElement>(".grid__empty");

      const valid = new Set(
        filters.map((btn) => btn.dataset.filter ?? "all"),
      );

      const apply = (active: string) => {
        let shown = 0;

        for (const li of items) {
          const families = (li.dataset.families ?? "").split(" ");
          const match = active === "all" || families.includes(active);
          li.hidden = !match;
          if (match) shown++;
        }

        for (const btn of filters) {
          const on = btn.dataset.filter === active;
          btn.classList.toggle("is-active", on);
          btn.setAttribute("aria-pressed", String(on));
        }

        if (empty) empty.hidden = shown > 0;
      };

      // Sync the URL ?topic= param without reloading.
      const syncUrl = (active: string) => {
        const url = new URL(window.location.href);
        if (active === "all") url.searchParams.delete("topic");
        else url.searchParams.set("topic", active);
        history.replaceState({ topic: active }, "", url);
      };

      // Read the current filter from the URL, falling back to "all".
      const fromUrl = () => {
        const topic = new URLSearchParams(window.location.search).get("topic");
        return topic && valid.has(topic) ? topic : "all";
      };

      const controller = new AbortController();
      for (const btn of filters) {
        btn.addEventListener(
          "click",
          () => {
            const active = btn.dataset.filter ?? "all";
            apply(active);
            syncUrl(active);
          },
          { signal: controller.signal },
        );
      }

      // Back/forward navigation updates the active filter.
      window.addEventListener("popstate", () => apply(fromUrl()), {
        signal: controller.signal,
      });

      // Honour a ?topic= param present on initial load / view transition.
      apply(fromUrl());

      cleanup = () => controller.abort();
    }

    document.addEventListener("astro:page-load", init);
    init();
  }
</script>
