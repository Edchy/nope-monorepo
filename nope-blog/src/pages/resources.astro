---
import { existsSync, readFileSync } from "fs";
import { createRequire } from "module";
import { dirname, resolve } from "path";
import Section from "../components/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const require = createRequire(import.meta.url);
const iconDirectory = resolve(
  dirname(require.resolve("@lobehub/icons-static-svg/package.json")),
  "icons",
);

const tools = [
  { name: "OpenAI", url: "https://openai.com", icon: "openai" },
  { name: "Claude", url: "https://claude.ai", icon: "claude" },
  { name: "Anthropic", url: "https://anthropic.com", icon: "anthropic" },
  { name: "Gemini", url: "https://gemini.google.com", icon: "gemini" },
  { name: "Runway", url: "https://runwayml.com", icon: "runway" },
  { name: "Ollama", url: "https://ollama.com", icon: "ollama" },
  { name: "Midjourney", url: "https://midjourney.com", icon: "midjourney" },
  { name: "Mistral", url: "https://mistral.ai", icon: "mistral" },
  { name: "Hugging Face", url: "https://huggingface.co", icon: "huggingface" },
  { name: "OpenRouter", url: "https://openrouter.ai", icon: "openrouter" },
  { name: "Perplexity", url: "https://perplexity.ai", icon: "perplexity" },
  { name: "Qwen", url: "https://qwen.ai", icon: "qwen" },
  { name: "Kling", url: "https://kling.ai", icon: "kling" },
  { name: "Luma", url: "https://lumalabs.ai", icon: "luma" },
  { name: "Antigravity", url: "https://antigravity.ai", icon: "antigravity" },
  {
    name: "Claude Code",
    url: "https://claude.com/claude-code",
    icon: "claudecode",
  },
  { name: "Codex", url: "https://openai.com/codex", icon: "codex" },
  { name: "Cursor", url: "https://cursor.sh", icon: "cursor" },
  { name: "DeepMind", url: "https://deepmind.google", icon: "deepmind" },
  { name: "DeepSeek", url: "https://deepseek.com", icon: "deepseek" },
  { name: "ElevenLabs", url: "https://elevenlabs.io", icon: "elevenlabs" },
  { name: "Figma", url: "https://figma.com", icon: "figma" },
  {
    name: "Gemini CLI",
    url: "https://github.com/google/gemini-cli",
    icon: "geminicli",
  },
  { name: "GitHub", url: "https://github.com", icon: "github" },
  {
    name: "GitHub Copilot",
    url: "https://github.com/features/copilot",
    icon: "copilot",
  },
  { name: "Kilo Code", url: "https://kilocode.ai", icon: "kilocode" },
  { name: "Jina AI", url: "https://jina.ai", icon: "jina" },
  { name: "Kimi", url: "https://kimi.moonshot.cn", icon: "kimi" },
  { name: "LM Studio", url: "https://lmstudio.ai", icon: "lmstudio" },
  { name: "LoVart", url: "https://lovart.ai", icon: "lovart" },
  { name: "MCP", url: "https://modelcontextprotocol.io", icon: "mcp" },
  { name: "Manus", url: "https://manus.im", icon: "manus" },
  { name: "MiniMax", url: "https://minimax.io", icon: "minimax" },
  { name: "n8n", url: "https://n8n.io", icon: "n8n" },
  { name: "Nano Banana", url: "https://nanobanana.ai", icon: "nanobanana" },
  { name: "Moonshot", url: "https://moonshot.ai", icon: "moonshot" },
  { name: "NotebookLM", url: "https://notebooklm.google", icon: "notebooklm" },
  { name: "Obsidian", url: "https://obsidian.md", icon: "obsidian" },
  { name: "Open Claw", url: "https://openclaw.ai", icon: "openclaw" },
  { name: "OpenCode", url: "https://opencode.ai", icon: "opencode" },
  { name: "Recraft", url: "https://recraft.ai", icon: "recraft" },
  { name: "Smithery", url: "https://smithery.ai", icon: "smithery" },
];

const toolsWithSvg = tools.map((tool) => {
  const colorIconPath = resolve(iconDirectory, `${tool.icon}-color.svg`);
  const iconPath = existsSync(colorIconPath)
    ? colorIconPath
    : resolve(iconDirectory, `${tool.icon}.svg`);

  return {
    ...tool,
    svg: readFileSync(iconPath, "utf8"),
  };
});
---

<BaseLayout title="Resources">
  <Section style="align-content: start; padding-block: var(--space-8);">
    <!-- <h1>Resources</h1> -->

    <ul class="icon-list">
      {
        toolsWithSvg.map((tool) => (
          <li>
            <a
              href={tool.url}
              target="_blank"
              rel="noopener"
              title={tool.name}
              set:html={tool.svg}
            />
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>

<style>
  .icon-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .icon-list li a {
    display: flex;
  }

  .icon-list li a :global(svg) {
    width: 28px;
    height: 28px;
  }
</style>
