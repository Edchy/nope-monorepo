---
import BaseLayout from "../layouts/BaseLayout.astro";
import Voxel from "../components/Voxel.astro";
---

<BaseLayout title="About">
  <section class="about-hero" aria-label="Voxel typography study">
    <Voxel />
  </section>
</BaseLayout>

<style>
  .about-hero {
    width: 100vw;
    margin-left: 50%;
    transform: translateX(-50%);
    background: #050505;
    padding: clamp(2.5rem, 5vw, 4.5rem) 0;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 40rem) {
    .about-hero {
      padding-block: 2rem 3rem;
    }
  }
</style>
