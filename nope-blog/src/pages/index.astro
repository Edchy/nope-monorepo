---
import BaseLayout from "../layouts/BaseLayout.astro";
import VoxelWork from "../components/VoxelWork.astro";
import { getCollection } from "astro:content";
import { quotes } from "../data/quotes";
import { navLinks } from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latestPost = posts[0];
const secondPost = posts[1];
---

<BaseLayout title="NOPE">
  <div class="home-grid">

    <!-- 1: Voxel -->
    <a href="https://nope.digital" class="cell cell--voxel" aria-label="Work" target="_blank" rel="noopener noreferrer">
      <VoxelWork />
      <span class="cell__label cell__meta">nope.digital ↗</span>
    </a>

    <!-- 2: Cycling quotes -->
    <div class="cell cell--quote" id="quote-cell" data-quotes={JSON.stringify(quotes)}>
      <blockquote class="cell__blockquote" id="quote-text"></blockquote>
      <p class="cell__source cell__meta cell__meta--end" id="quote-source"></p>
    </div>

    <!-- 3: Art Int -->
    <a href="/artificial" class="cell cell--dark cell--lift" data-lift-max="18">
      <span class="cell__label-lg">{navLinks[3]?.label}</span>
      <span class="cell__sublabel cell__meta">artyficiál intél</span>
    </a>

    <!-- 2: Latest blog post -->
    {latestPost && (
      <a
        href={`/writing/${latestPost.id.replace(/\/index$/, "")}`}
        class="cell cell--post cell--lift"
        data-lift-max="18"
      >
        <p class="cell__eyebrow cell__meta">Latest post</p>
        <h2 class="cell__title" transition:name={`post-title-${latestPost.id}`}>{latestPost.data.title}</h2>
        {latestPost.data.description && (
          <p class="cell__desc cell__meta">{latestPost.data.description}</p>
        )}
        <p class="cell__date cell__meta cell__meta--end">
          {latestPost.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </p>
      </a>
    )}

    <!-- 1: Gallery -->
    <a href="/room" class="cell cell--gallery cell--lift" data-lift-max="18">
      <span class="cell__label-lg">{navLinks[1]?.label}</span>
      <span class="cell__sublabel cell__meta">3D work &amp; experiments</span>
    </a>

  </div>
</BaseLayout>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 50svh 50svh;
    min-height: 100svh;
    gap: 0;
    overflow-anchor: none;
  }

  /* Base cell */
  .cell {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    border: none;
    text-transform: uppercase;
  }

  .cell--lift {
    --_tx: 0px;
    --_ty: 0px;
    --_scale: 1;
    transform: translate(var(--_tx), var(--_ty)) scale(var(--_scale));
    transform-origin: center;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  /* ── Voxel cell ── */
  .cell--voxel {
    grid-column: span 2;
    justify-content: stretch;
    padding: 0;
    background: var(--neutral-900);
    color: var(--neutral-50);
    transition: background-color 0.45s ease;
  }

  .cell--voxel :global(canvas),
  .cell--voxel :global(.voxel-work) {
    width: 100% !important;
    height: 100% !important;
    position: absolute;
    inset: 0;
  }

  .cell--voxel .cell__label {
    position: absolute;
    bottom: var(--space-6);
    left: var(--space-6);
    z-index: 2;
  }

  /* ── Blog post cells ── */
  .cell--post {
    background: var(--experimental-1);
    color: var(--neutral-50);
    gap: var(--space-3);
  }

  .cell--post-alt {
    background: var(--neutral-100);
  }

  .cell__eyebrow {
    margin: 0;
  }

  .cell__label-lg,
  .cell__title {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .cell__desc {
    margin: 0;
    line-height: var(--line-height-relaxed);
  }

  .cell__date {
    margin: auto 0 0 auto;
  }

  /* ── Quote cell ── */
  .cell--quote {
    background: var(--color-background);
    color: var(--color-text-primary);
    justify-content: space-between;
    padding: var(--space-8) var(--space-6);
    transition:
      background-color 0.45s ease,
      color 0.45s ease;
  }

  .cell__blockquote {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-relaxed);
    letter-spacing: -0.01em;
  }

  .cell__source {
    margin: 0;
  }

  /* ── Gallery cell ── */
  .cell--gallery {
    background: var(--neutral-800);
    color: var(--neutral-50);
    gap: var(--space-2);
  }

  /* ── Dark / Art Int cell ── */
  .cell--dark {
    background: var(--experimental-2);
    color: var(--experimental-1);
    gap: var(--space-2);
  }

  /* ── Shared typographic pieces ── */
  .cell__meta {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    line-height: var(--line-height-relaxed);
    color: currentColor;
    opacity: 0.62;
  }

  .cell__meta--end {
    align-self: flex-end;
  }

  @media (hover: hover) and (pointer: fine) {
    .cell--voxel:hover {
      background: var(--experimental-2);
    }

    .cell--quote:hover {
      background: var(--color-text-primary);
      color: var(--color-background);
    }

    .cell--lift:is(:hover, :focus-visible) {
      z-index: 2;
    }
  }

  /* ── Mobile: stack to 2-col, then 1-col ── */
  @media (max-width: 900px) {
    .home-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 50vw 40svh 50vw;
    }

    .cell--voxel {
      grid-column: 1 / -1;
      grid-row: 3;
    }

    .cell--post {
      grid-column: 1;
      grid-row: 1;
    }

    .cell--quote {
      grid-column: 2;
      grid-row: 2;
    }

    .cell--gallery {
      grid-column: 2;
      grid-row: 1;
    }

    .cell--dark {
      grid-column: 1;
      grid-row: 2;
    }
  }

  @media (max-width: 480px) {
    .home-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-auto-rows: minmax(12rem, auto);
      min-height: 0;
    }

    .cell--post,
    .cell--gallery,
    .cell--dark,
    .cell--quote,
    .cell--voxel {
      grid-column: 1;
    }

    .cell--post {
      grid-row: 1;
    }

    .cell--gallery {
      grid-row: 2;
    }

    .cell--dark {
      grid-row: 3;
    }

    .cell--quote {
      grid-row: 4;
    }

    .cell--voxel {
      grid-row: 5;
      min-height: 60vw;
    }

    .cell--quote {
      min-height: 18rem;
    }

    .cell--dark,
    .cell--gallery,
    .cell--post {
      min-height: 12rem;
    }
  }

  @media (max-width: 768px) {
    .cell--lift {
      transform: none;
      transition: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cell--lift {
      transition: none;
    }
  }

  /* ── Quote transition ── */
  #quote-cell blockquote,
  #quote-cell p {
    transition: opacity 0.5s ease;
  }

  #quote-cell.is-transitioning blockquote,
  #quote-cell.is-transitioning p {
    opacity: 0;
  }
</style>

<script>
  let cleanupLiftCells: (() => void) | undefined;

  const canUseLiftInteractions = () =>
    window.matchMedia("(min-width: 769px)").matches &&
    window.matchMedia("(hover: hover) and (pointer: fine)").matches &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const resetLiftStyles = (cell: HTMLElement) => {
    cell.style.setProperty("--_tx", "0px");
    cell.style.setProperty("--_ty", "0px");
    cell.style.setProperty("--_scale", "1");
  };

  function initQuotes() {
    const cell = document.getElementById("quote-cell");
    const textEl = document.getElementById("quote-text");
    const sourceEl = document.getElementById("quote-source");
    if (!cell || !textEl || !sourceEl) return;

    const quotes = JSON.parse(cell.dataset.quotes ?? "[]") as Array<{
      text: string;
      source?: string;
      author?: string;
      href?: string;
    }>;

    if (!quotes.length) return;

    let index = 0;

    function render(q: typeof quotes[number]) {
      textEl!.textContent = `"${q.text}"`;
      const label = q.source ?? q.author ?? "";
      sourceEl!.textContent = label;
    }

    function advance() {
      cell!.classList.add("is-transitioning");
      setTimeout(() => {
        index = (index + 1) % quotes.length;
        render(quotes[index]);
        cell!.classList.remove("is-transitioning");
      }, 500);
    }

    render(quotes[0]);
    const interval = setInterval(advance, 10000);

    document.addEventListener("astro:before-swap", () => clearInterval(interval), { once: true });
  }

  document.addEventListener("astro:page-load", initQuotes);
  initQuotes();

  function initLiftCells() {
    cleanupLiftCells?.();

    const cells = document.querySelectorAll<HTMLElement>(".cell--lift");
    if (!cells.length) {
      cleanupLiftCells = undefined;
      return;
    }

    if (!canUseLiftInteractions()) {
      cells.forEach((cell) => resetLiftStyles(cell));
      cleanupLiftCells = undefined;
      return;
    }

    const controller = new AbortController();
    const { signal } = controller;

    cells.forEach((cell) => {
      const max = Number(cell.dataset.liftMax ?? 18);

      cell.addEventListener(
        "mousemove",
        (event) => {
          const rect = cell.getBoundingClientRect();
          const nx = (event.clientX - rect.left) / rect.width;
          const ny = (event.clientY - rect.top) / rect.height;

          cell.style.setProperty("--_tx", `${nx * max}px`);
          cell.style.setProperty("--_ty", `${-(ny * max)}px`);
          cell.style.setProperty("--_scale", "1.04");
        },
        { signal },
      );

      cell.addEventListener(
        "mouseleave",
        () => {
          resetLiftStyles(cell);
        },
        { signal },
      );
    });

    cleanupLiftCells = () => {
      controller.abort();
      cells.forEach((cell) => resetLiftStyles(cell));
    };
  }

  document.addEventListener("astro:page-load", initLiftCells);
  document.addEventListener("astro:before-swap", () => cleanupLiftCells?.(), {
    once: true,
  });
  initLiftCells();
</script>
