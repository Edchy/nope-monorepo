---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { quotes } from "../data/quotes";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latest = posts[0];

function postHref(id: string) {
  return `/writing/${id.replace(/\/index\.md$/, "").replace(/\.md$/, "")}`;
}

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<BaseLayout title="NOPE" description="Notes on building, design, and the web.">
  <div class="home">
    <div class="container">
      <header class="home__intro">
        <h1 class="home__tagline">My corner of the interwebz, where I post, write about stuff, and experiment and shit like that.</h1>
      </header>

      <div class="cards">
        <!-- Latest post — primary -->
        {latest && (
          <div class="card card--feature">
            <span class="card__eyebrow">Latest post</span>
            <h2 class="card__title" transition:name={`post-title-${latest.id}`}>
              <a href={postHref(latest.id)} class="card__title-link">{latest.data.title}</a>
            </h2>
            {latest.data.description && (
              <p class="card__desc">{latest.data.description}</p>
            )}
            <span class="card__foot">
              <span class="card__date">{fmtDate(latest.data.date)}</span>
              <a href="/writing" class="card__cta card__cta--link">All writing →</a>
            </span>
          </div>
        )}

        <!-- 3D Room -->
        <a href="/room" class="card">
          <span class="card__eyebrow">Experiment</span>
          <h2 class="card__title card__title--sm">3DRoom</h2>
          <p class="card__desc">A walkable 3D gallery of work &amp; experiments.</p>
          <span class="card__foot">
            <span class="card__cta">Enter →</span>
          </span>
        </a>

        <!-- Untangled -->
        <a href="https://untangled.se" class="card" target="_blank" rel="noopener noreferrer">
          <span class="card__eyebrow">Experiment</span>
          <h2 class="card__title card__title--sm">
            Untangled <span class="card__ext" aria-hidden="true">↗</span>
          </h2>
          <p class="card__desc">An AI learning platform I'm building.</p>
          <span class="card__foot">
            <span class="card__cta">untangled.se</span>
          </span>
        </a>

      </div>

      <aside class="quote" id="quote-cell" data-quotes={JSON.stringify(quotes)} aria-label="A line I like">
        <blockquote class="quote__text" id="quote-text"></blockquote>
        <p class="quote__source" id="quote-source"></p>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .home {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--2);
    color: var(--3);
    padding-block: clamp(3.5rem, 9vw, 7rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  .container {
    max-width: var(--max-width-site);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-container);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ── Intro ── */
  .home__intro {
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .home__tagline {
    margin: 0;
    font-family: var(--font-zt-nature);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
    color: var(--3);
    max-width: 24ch;
    text-wrap: balance;
  }

  /* ── Card grid ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.75rem, 2vw, 1.25rem);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: clamp(1.4rem, 3vw, 2rem);
    border: var(--border-width-1) solid var(--color-border-default);
    border-radius: 0;
    background: var(--2);
    color: var(--3);
    text-decoration: none;
    transition:
      border-color 0.18s ease,
      transform 0.2s var(--motion-ease-decelerate);
  }

  /* Feature post spans full width and pops with inverted ink */
  .card--feature {
    grid-column: 1 / -1;
    background: var(--3);
    color: var(--2);
    border-color: var(--3);
    min-height: clamp(11rem, 24vw, 15rem);
  }

  .card__eyebrow {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .card__title {
    font-family: var(--font-zt-nature);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.025em;
    margin: 0;
    text-wrap: balance;
  }

  .card__title--sm {
    font-size: var(--font-size-xl);
  }

  .card__title-link {
    color: inherit;
    text-decoration: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .card__title-link:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 2px;
    }
  }

  .card__ext {
    font-size: 0.7em;
    vertical-align: middle;
    opacity: 0.6;
  }

  .card__desc {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    opacity: 0.72;
    text-wrap: pretty;
  }

  .card__foot {
    margin-top: auto;
    padding-top: var(--space-3);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card__date {
    opacity: 0.6;
  }

  .card__cta {
    opacity: 0.85;
  }

  .card__cta--link {
    color: inherit;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.12s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .card__cta--link:hover {
      opacity: 1;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  }

  /* ── Quote (centered, above footer) ── */
  .quote {
    margin-top: auto;
    padding-top: clamp(4rem, 12vw, 8rem);
    text-align: center;
    max-width: 52ch;
    margin-inline: auto;
  }

  .quote__text {
    margin: 0;
    font-family: var(--font-family-prose);
    font-size: var(--font-size-base);
    font-style: italic;
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .quote__source {
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .quote__text,
  .quote__source {
    transition: opacity 0.5s ease;
  }

  .quote.is-transitioning .quote__text,
  .quote.is-transitioning .quote__source {
    opacity: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    a.card:hover {
      border-color: var(--color-border-strong);
      transform: translateY(-3px);
    }

    a.card--feature:hover {
      border-color: var(--3);
      transform: translateY(-3px);
    }
  }

  @media (max-width: 620px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initQuotes() {
    const cell = document.getElementById("quote-cell");
    const textEl = document.getElementById("quote-text");
    const sourceEl = document.getElementById("quote-source");
    if (!cell || !textEl || !sourceEl) return;

    const quotes = JSON.parse(cell.dataset.quotes ?? "[]") as Array<{
      text: string;
      source?: string;
      author?: string;
    }>;

    if (!quotes.length) return;

    let index = Math.floor(Math.random() * quotes.length);

    function render(q: (typeof quotes)[number]) {
      textEl!.textContent = `"${q.text}"`;
      const label = q.source ?? q.author ?? "";
      sourceEl!.textContent = label ? `— ${label}` : "";
    }

    function advance() {
      cell!.classList.add("is-transitioning");
      setTimeout(() => {
        index = (index + 1) % quotes.length;
        render(quotes[index]);
        cell!.classList.remove("is-transitioning");
      }, 500);
    }

    render(quotes[index]);
    const interval = setInterval(advance, 12000);

    document.addEventListener("astro:before-swap", () => clearInterval(interval), {
      once: true,
    });
  }

  document.addEventListener("astro:page-load", initQuotes);
  initQuotes();
</script>
