---
import BaseLayout from "../layouts/BaseLayout.astro";
import VoxelWork from "../components/VoxelWork.astro";
import { getCollection } from "astro:content";
import { quotes } from "../data/quotes";

const colorTokens = [
  "var(--neutral-50)",
  "var(--neutral-100)",
  "var(--neutral-200)",
  "var(--neutral-300)",
  "var(--neutral-400)",
  "var(--neutral-500)",
  "var(--neutral-600)",
  "var(--neutral-700)",
  "var(--neutral-800)",
  "var(--neutral-900)",
  "var(--neutral-950)",
  "var(--neutral-warm-600)",
  "var(--experimental-1)",
  "var(--experimental-2)",
  "var(--experimental-3)",
  "var(--color-background)",
  "var(--color-background-surface)",
  "var(--color-background-subtle)",
  "var(--color-text-secondary)",
  "var(--color-text-disabled)",
  "var(--color-text-inverse)",
  "var(--color-action-primary)",
  "var(--color-action-primary-hover)",
  "var(--color-border-default)",
  "var(--color-border-strong)",
];

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latestPost = posts[0];
const secondPost = posts[1];
---

<BaseLayout title="NOPE">
  <div class="home-grid">

    <!-- 1: Voxel -->
    <a href="https://nope.digital" class="cell cell--voxel" aria-label="Work" target="_blank" rel="noopener noreferrer">
      <VoxelWork />
      <span class="cell__label">nope.digital ↗</span>
    </a>

    <!-- 2: Cycling quotes -->
    <div class="cell cell--quote" id="quote-cell" data-quotes={JSON.stringify(quotes)}>
      <blockquote class="cell__blockquote" id="quote-text"></blockquote>
      <p class="cell__source" id="quote-source"></p>
    </div>

    <!-- 3: Art Int -->
    <a href="/art-int" class="cell cell--dark">
      <span class="cell__label-lg">Art Int</span>
      <span class="cell__sublabel">Art &amp; intelligence</span>
    </a>

    <!-- 4: Gallery -->
    <a
      href="/gallery"
      class="cell cell--gallery"
      data-colors={JSON.stringify(colorTokens)}
    >
      <span class="cell__label-lg">Gallery</span>
      <span class="cell__sublabel">3D work &amp; experiments</span>
    </a>

    <!-- 5: Latest blog post -->
    {latestPost && (
      <a
        href={`/blog/${latestPost.id.replace(/\/index$/, "")}`}
        class="cell cell--post"
      >
        <p class="cell__eyebrow">Latest post</p>
        <h2 class="cell__title">{latestPost.data.title}</h2>
        {latestPost.data.description && (
          <p class="cell__desc">{latestPost.data.description}</p>
        )}
        <p class="cell__date">
          {latestPost.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </p>
      </a>
    )}

  </div>
</BaseLayout>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 50svh 50svh;
    min-height: 100svh;
    gap: 0;
  }

  /* Base cell */
  .cell {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    border: none;
    transition: background-color 0.2s ease;
  }

  /* ── Voxel cell ── */
  .cell--voxel {
    grid-column: span 2;
    justify-content: stretch;
    padding: 0;
    background: #050505;
  }

  .cell--voxel :global(canvas),
  .cell--voxel :global(.voxel-work) {
    width: 100% !important;
    height: 100% !important;
    position: absolute;
    inset: 0;
  }

  .cell--voxel .cell__label {
    position: absolute;
    bottom: var(--space-6);
    left: var(--space-6);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    z-index: 2;
    transition: color 0.2s ease;
  }

  .cell--voxel:hover .cell__label {
    color: rgba(255, 255, 255, 1);
  }

  /* ── Blog post cells ── */
  .cell--post {
    background: var(--color-background-surface);
    gap: var(--space-2);
  }

  .cell--post:hover {
    background: var(--neutral-100);
  }

  .cell--post-alt {
    background: var(--neutral-100);
  }

  .cell--post-alt:hover {
    background: var(--neutral-200);
  }

  .cell__eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .cell__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .cell__desc {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .cell__date,
  .cell__tags {
    margin: var(--space-2) 0 0 auto;
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }

  .cell__tags {
    text-transform: lowercase;
  }

  /* ── Quote cell ── */
  .cell--quote {
    background: var(--color-background);
    color: var(--color-text-primary);
    justify-content: space-between;
    padding: var(--space-8) var(--space-6);
  }

  .cell--quote:hover {
    background: color-mix(in oklch, var(--color-background) 92%, black);
  }

  .cell__blockquote {
    margin: 0;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-snug);
    letter-spacing: -0.01em;
  }

  .cell__source {
    margin: 0;
    font-size: var(--font-size-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    align-self: flex-end;
  }

  /* ── Gallery cell ── */
  .cell--gallery {
    background: var(--neutral-800);
    color: var(--neutral-50);
    gap: var(--space-2);
    transition: filter 0.2s ease;
  }

  .cell--gallery:hover {
    filter: brightness(0.92);
  }

  /* ── Dark / Art Int cell ── */
  .cell--dark {
    background: var(--experimental-2);
    color: var(--experimental-1);
    gap: var(--space-2);
  }

  .cell--dark:hover {
    background: color-mix(in oklch, var(--experimental-2) 90%, black);
  }

  /* ── Shared typographic pieces ── */
  .cell__label-lg {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.03em;
    line-height: var(--line-height-tight);
  }

  .cell__sublabel {
    font-size: var(--font-size-sm);
    opacity: 0.5;
    letter-spacing: 0.04em;
  }

  /* ── Mobile: stack to 2-col, then 1-col ── */
  @media (max-width: 900px) {
    .home-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 50vw 40svh 50vw;
    }

    .cell--voxel {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .cell--post {
      grid-column: 2;
      grid-row: 3;
    }

    .cell--quote {
      grid-column: 2;
      grid-row: 2;
    }

    .cell--gallery {
      grid-column: 1;
      grid-row: 3;
    }

    .cell--dark {
      grid-column: 1;
      grid-row: 2;
    }
  }

  @media (max-width: 480px) {
    .home-grid {
      grid-template-columns: 1fr;
    }

    .cell--voxel {
      grid-column: span 1;
      min-height: 60vw;
    }
  }

  /* ── Quote transition ── */
  #quote-cell blockquote,
  #quote-cell p {
    transition: opacity 0.5s ease;
  }

  #quote-cell.is-transitioning blockquote,
  #quote-cell.is-transitioning p {
    opacity: 0;
  }
</style>

<script>
  function initQuotes() {
    const cell = document.getElementById("quote-cell");
    const textEl = document.getElementById("quote-text");
    const sourceEl = document.getElementById("quote-source");
    if (!cell || !textEl || !sourceEl) return;

    const quotes = JSON.parse(cell.dataset.quotes ?? "[]") as Array<{
      text: string;
      source?: string;
      author?: string;
      href?: string;
    }>;

    if (!quotes.length) return;

    let index = 0;

    function render(q: typeof quotes[number]) {
      textEl!.textContent = `"${q.text}"`;
      const label = q.source ?? q.author ?? "";
      sourceEl!.textContent = label;
    }

    function advance() {
      cell!.classList.add("is-transitioning");
      setTimeout(() => {
        index = (index + 1) % quotes.length;
        render(quotes[index]);
        cell!.classList.remove("is-transitioning");
      }, 500);
    }

    render(quotes[0]);
    const interval = setInterval(advance, 10000);

    document.addEventListener("astro:before-swap", () => clearInterval(interval), { once: true });
  }

  document.addEventListener("astro:page-load", initQuotes);
  initQuotes();

  function initColors() {
    const cells = Array.from(document.querySelectorAll<HTMLElement>("[data-colors]"));
    if (!cells.length) return;

    const intervals: number[] = [];

    cells.forEach((cell) => {
      const colors = JSON.parse(cell.dataset.colors ?? "[]") as string[];
      if (!colors.length) return;

      let index = 0;

      const render = (color: string) => {
        cell.style.backgroundColor = color;
      };

      const advance = () => {
        index = (index + 1) % colors.length;
        render(colors[index]);
      };

      render(colors[0]);
      intervals.push(window.setInterval(advance, 1200));
    });

    document.addEventListener(
      "astro:before-swap",
      () => intervals.forEach((interval) => clearInterval(interval)),
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initColors);
  initColors();
</script>
