---
import { Font } from "astro:assets";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "@nope/ui/src/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  noFooter?: boolean;
  noHeader?: boolean;
  darkHeader?: boolean;
}

const {
  title,
  description = "Just Nope",
  noFooter = false,
  noHeader = false,
  darkHeader = false,
} = Astro.props;

export const navLinks = [
  { href: "/writing", label: "Writing" },
  { href: "/room", label: "Room" },
  { href: "/about", label: "Me" },
  { href: "https://nope.digital", label: "nope", isExternal: true },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <ClientRouter />
    <script is:inline>
      const syncMobileTransitionMode = () => {
        const isMobile = window.matchMedia("(max-width: 768px)").matches;
        const enabledMeta = document.querySelector(
          'meta[name="astro-view-transitions-enabled"]',
        );
        const fallbackMeta = document.querySelector(
          'meta[name="astro-view-transitions-fallback"]',
        );

        if (isMobile) {
          enabledMeta?.remove();
          fallbackMeta?.remove();
          return;
        }

        if (!enabledMeta) {
          const meta = document.createElement("meta");
          meta.name = "astro-view-transitions-enabled";
          meta.content = "true";
          document.head.append(meta);
        }

        if (!fallbackMeta) {
          const meta = document.createElement("meta");
          meta.name = "astro-view-transitions-fallback";
          meta.content = "animate";
          document.head.append(meta);
        }
      };

      syncMobileTransitionMode();
      document.addEventListener("astro:page-load", syncMobileTransitionMode);
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://blog.nope.digital/images/og-image.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://blog.nope.digital/images/og-image.jpg" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-zt-nature" preload={true} />
    <Font cssVariable="--font-literata" preload={true} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    {!noHeader && <Header navLinks={navLinks} dark={darkHeader} />}

    <main id="main-content" class="site-main" tabindex="-1" transition:name="shell-main" transition:animate="none">
      <slot />
    </main>

    {!noFooter && <Footer siteTitle="NOPE" />}
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: var(--2);
    color: var(--3);
    text-decoration: none;
    font-size: var(--font-size-sm);
    z-index: 9999;
    border: var(--border-width-1) solid var(--color-border-default);
  }

  .skip-link:focus {
    top: var(--space-4);
    outline: 3px solid var(--color-action-primary);
    outline-offset: 2px;
  }

  .site-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .site-main:focus {
    outline: none;
  }
</style>
