---
import BaseLayout from './BaseLayout.astro';

interface NavLink {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  author?: string;
  postId?: string;
  prev?: NavLink | null;
  next?: NavLink | null;
}

const { title, description, date, postId, prev, next } = Astro.props;
---

<BaseLayout title={title} description={description} noFooter>
  <article class="post">
    <header class="post__header">
      <div class="post__header-content">
        <h1 class="post__title" transition:name={postId ? `post-title-${postId}` : undefined}>{title}</h1>
        {(date || description) && (
          <div class="post__meta">
            {date && <p class="post__date">{date}</p>}
            {description && <p class="post__desc">{description}</p>}
          </div>
        )}
      </div>
    </header>
    <div class="post__body post__constrained">
      <slot />
    </div>
    <footer class="post-nav">
    <div class="post-nav__item post-nav__item--prev">
      {prev ? (
        <a href={prev.href} class="post-nav__link">
          <span class="post-nav__label">Previous</span>
          <span class="post-nav__title">{prev.title}</span>
        </a>
      ) : null}
    </div>
    <div class="post-nav__item post-nav__item--home">
      <a href="/writing" class="post-nav__link post-nav__link--home">
        <span class="post-nav__label">All posts</span>
      </a>
    </div>
    <div class="post-nav__item post-nav__item--next">
      {next ? (
        <a href={next.href} class="post-nav__link">
          <span class="post-nav__label">Next</span>
          <span class="post-nav__title">{next.title}</span>
        </a>
      ) : null}
    </div>
    </footer>
  </article>
</BaseLayout>

<style>
  /* ── Container ── */
  .post {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .post__body.post__constrained,
  .post-nav {
    padding-inline: clamp(1.25rem, 5vw, 2rem);
  }

  .post__constrained {
    max-width: 62ch;
    margin-inline: auto;
    width: 100%;
  }

  .post__body.post__constrained {
    padding: 0 0 clamp(4rem, 10vw, 8rem);
  }

  /* ── Header ── */
  .post__header {
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: clamp(2rem, 5vw, 3rem);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
    background: var(--2);
    color: var(--3);
  }

  .post__header-content {
    width: 100%;
  }

  .post__title {
    font-family: var(--font-zt-nature);
    font-size: clamp(2.75rem, 8vw, 6.5rem);
    font-weight: var(--font-weight-black);
    line-height: 0.9;
    letter-spacing: -0.035em;
    margin: 0;
    color: inherit;
    text-wrap: balance;
  }

  @media (max-width: 767px) {
    .post__header {
      align-items: center;
    }
    .post__meta {
      display: none;
    }
    .post__body.post__constrained,
    .post-nav {
      padding-inline: var(--space-4);
    }
  }

  .post__meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: clamp(2rem, 5vw, 3rem);
  }

  .post__date {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: inherit;
    opacity: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .post__desc {
    font-size: var(--font-size-base);
    line-height: 1.55;
    color: inherit;
    opacity: 0.6;
    margin: 0;
    max-width: 52ch;
    text-wrap: pretty;
  }

  /* ── Body prose ── */
  .post__body {
    font-family: var(--font-family-prose);
    font-size: var(--font-size-base);
    line-height: 1.75;
    color: var(--color-text-primary);
  }

  /* Paragraphs */
  .post__body :global(p) {
    margin: 0 0 1.5em;
  }

  /* Headings */
  .post__body :global(h2),
  .post__body :global(h3),
  .post__body :global(h4),
  .post__body :global(h5) {
    font-family: var(--font-zt-nature);
    font-weight: var(--font-weight-bold);
    line-height: 1.25;
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  .post__body :global(h2) {
    font-size: var(--font-size-xl);
    letter-spacing: -0.025em;
    margin: 3em 0 0.35em;
  }

  .post__body :global(h3) {
    font-size: var(--font-size-lg);
    letter-spacing: -0.02em;
    margin: 2.5em 0 0.25em;
  }

  .post__body :global(h4) {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    letter-spacing: -0.01em;
    margin: 2em 0 0.2em;
  }

  .post__body :global(h5) {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0;
    margin: 1.5em 0 0.2em;
    color: var(--color-text-secondary);
  }

  /* Tighten when heading follows heading */
  .post__body :global(h2 + h3),
  .post__body :global(h3 + h4),
  .post__body :global(h4 + h5) {
    margin-top: 0.75em;
  }

  /* First element — no extra top gap */
  .post__body :global(> *:first-child) {
    margin-top: 0;
  }

  /* Links */
  .post__body :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in oklch, currentColor 35%, transparent);
    transition: text-decoration-color 150ms ease;
  }

  .post__body :global(a:hover) {
    text-decoration-color: currentColor;
  }

  /* HR */
  .post__body :global(hr) {
    border: none;
    margin: 0;
  }

  /* Blockquote */
  .post__body :global(blockquote) {
    margin: 2em 0;
    padding-left: 1.25em;
    border-left: 2px solid color-mix(in oklch, var(--color-text-primary) 20%, transparent);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post__body :global(blockquote p) {
    margin: 0;
  }

  /* Lists */
  .post__body :global(ul),
  .post__body :global(ol) {
    padding-left: 1.4em;
    margin: 0 0 1.5em;
  }

  .post__body :global(li) {
    margin-bottom: 0.4em;
    line-height: 1.65;
  }

  .post__body :global(li:last-child) {
    margin-bottom: 0;
  }

  /* Inline code */
  .post__body :global(code) {
    font-size: 0.875em;
    background: color-mix(in oklch, var(--color-text-primary) 6%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-variant-ligatures: none;
  }

  /* Code blocks */
  .post__body :global(pre) {
    background: color-mix(in oklch, var(--color-text-primary) 5%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-text-primary) 10%, transparent);
    padding: 1.4em 1.6em;
    overflow-x: auto;
    margin: 2em 0;
    border-radius: 4px;
    font-size: 0.875em;
    line-height: 1.65;
  }

  .post__body :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
    border-radius: 0;
  }

  /* Images */
  .post__body :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2.5em auto;
  }

  /* Strong / em */
  .post__body :global(strong) {
    font-weight: var(--font-weight-semibold);
  }

  /* Footnote-style italicised closing lines — use class="footnote" on the <em> */
  .post__body :global(em.footnote) {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  /* ── Post nav footer ── */
  .post-nav {
    max-width: 62ch;
    width: 100%;
    margin-inline: auto;
    padding-bottom: clamp(4rem, 10vw, 8rem);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    border-top: var(--border-width-1) solid var(--color-border-default);
  }

  .post-nav__item {
    display: flex;
    align-items: stretch;
  }

  .post-nav__item .post-nav__link {
    flex: 1;
  }

  .post-nav__item--next {
    justify-content: flex-end;
  }

  .post-nav__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-6);
    text-decoration: none;
    color: var(--color-text-primary);
    border-right: var(--border-width-1) solid var(--color-border-default);
    transition: background 150ms ease;
  }

  .post-nav__item--next .post-nav__link {
    border-right: none;
    border-left: var(--border-width-1) solid var(--color-border-default);
    align-items: flex-end;
    text-align: right;
  }

  .post-nav__item--home .post-nav__link {
    border: none;
    align-items: center;
    justify-content: center;
  }

  .post-nav__link:not(.post-nav__link--disabled):hover {
    background: color-mix(in oklch, var(--color-text-primary) 4%, transparent);
  }

  .post-nav__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .post-nav__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .post-nav {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .post-nav__item--prev { order: 1; }
    .post-nav__item--next { order: 2; }
    .post-nav__item--home { order: 3; }

    .post-nav__link {
      border-right: none;
      border-bottom: var(--border-width-1) solid var(--color-border-default);
    }

    .post-nav__item--next .post-nav__link {
      border-left: none;
      border-bottom: var(--border-width-1) solid var(--color-border-default);
      align-items: flex-start;
      text-align: left;
    }

    .post-nav__item--home .post-nav__link {
      border-bottom: none;
    }
  }
</style>
