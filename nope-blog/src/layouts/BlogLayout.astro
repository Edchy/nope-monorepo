---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  author?: string;
  postId?: string;
}

const { title, description, date, postId } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <div class="back-anchor">
      <a href="/writing" class="back-btn" aria-label="Back to writing">←</a>
    </div>
    <a href="/writing" class="back-inline">← Writing</a>
    <header class="post__header">
      {date && <p class="post__date">{date}</p>}
      <h1 class="post__title" transition:name={postId ? `post-title-${postId}` : undefined}>{title}</h1>
      {description && <p class="post__desc">{description}</p>}
    </header>
    <div class="post__body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  /* ── Back button ── */
  .back-anchor {
    position: sticky;
    top: clamp(3rem, 8vw, 6rem);
    height: 0;
    overflow: visible;
  }

  .back-btn {
    position: absolute;
    left: calc(-2.25rem - var(--space-3));
    top: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--border-radius-full);
    background: transparent;
    border: none;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-base);
    transition: color 150ms ease, transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .back-btn:hover {
    color: var(--color-text-primary);
    transform: translateX(-2px);
  }

  /* Hide when there's no room to the left of the article */
  @media (max-width: 1000px) {
    .back-anchor {
      display: none;
    }
  }

  .back-inline {
    display: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-secondary);
    transition: color 150ms ease;
    margin-bottom: var(--space-8);
  }

  .back-inline:hover {
    color: var(--color-text-primary);
  }

  @media (max-width: 1000px) {
    .back-inline {
      display: inline-block;
    }
  }

  /* ── Container ── */
  .post {
    width: 100%;
    max-width: 62ch;
    margin-inline: auto;
    padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 5vw, 2rem) clamp(4rem, 10vw, 8rem);
  }

  /* ── Header ── */
  .post__header {
    margin-bottom: clamp(3rem, 8vw, 5rem);
  }

  .post__date {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: 0.04em;
    margin: 0 0 1.25rem;
    font-variant-numeric: tabular-nums;
  }

  .post__title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--color-text-primary);
  }

  .post__desc {
    margin: 1.25rem 0 0;
    font-size: var(--font-size-base);
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ── Body prose ── */
  .post__body {
    font-family: var(--font-newsreader);
    font-size: var(--font-size-base);
    line-height: 1.75;
    color: var(--color-text-primary);
  }

  /* Reset headings to base font */
  .post__body :global(h2),
  .post__body :global(h3),
  .post__body :global(h4) {
    font-family: var(--font-nature);
  }

  /* Paragraphs */
  .post__body :global(p) {
    margin: 0 0 1.5em;
  }

  /* Headings — hierarchy through contrast in size, weight, and space above */
  .post__body :global(h2) {
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 3.5em 0 0.6em;
    color: var(--color-text-primary);
  }

  .post__body :global(h3) {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    letter-spacing: -0.01em;
    line-height: 1.4;
    margin: 2.5em 0 0.4em;
    color: var(--color-text-primary);
  }

  .post__body :global(h4) {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.4;
    margin: 2em 0 0.4em;
    color: var(--color-text-secondary);
  }

  /* Tighten spacing when heading immediately follows another heading */
  .post__body :global(h2 + h3),
  .post__body :global(h3 + h4) {
    margin-top: 1em;
  }

  /* Links */
  .post__body :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in oklch, currentColor 35%, transparent);
    transition: text-decoration-color 150ms ease;
  }

  .post__body :global(a:hover) {
    text-decoration-color: currentColor;
  }

  /* HR */
  .post__body :global(hr) {
    border: none;
    border-top: 1px solid color-mix(in oklch, var(--color-text-primary) 12%, transparent);
    margin: 3em 0;
  }

  /* Blockquote */
  .post__body :global(blockquote) {
    margin: 2em 0;
    padding-left: 1.25em;
    border-left: 2px solid color-mix(in oklch, var(--color-text-primary) 20%, transparent);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post__body :global(blockquote p) {
    margin: 0;
  }

  /* Lists */
  .post__body :global(ul),
  .post__body :global(ol) {
    padding-left: 1.4em;
    margin: 0 0 1.5em;
  }

  .post__body :global(li) {
    margin-bottom: 0.4em;
    line-height: 1.65;
  }

  .post__body :global(li:last-child) {
    margin-bottom: 0;
  }

  /* Inline code */
  .post__body :global(code) {
    font-size: 0.875em;
    background: color-mix(in oklch, var(--color-text-primary) 6%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-variant-ligatures: none;
  }

  /* Code blocks */
  .post__body :global(pre) {
    background: color-mix(in oklch, var(--color-text-primary) 5%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-text-primary) 10%, transparent);
    padding: 1.4em 1.6em;
    overflow-x: auto;
    margin: 2em 0;
    border-radius: 4px;
    font-size: 0.875em;
    line-height: 1.65;
  }

  .post__body :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
    border-radius: 0;
  }

  /* Images */
  .post__body :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2.5em 0;
  }

  /* Strong / em */
  .post__body :global(strong) {
    font-weight: var(--font-weight-semibold);
  }

  /* Footnote-style italicised closing lines */
  .post__body :global(p > em:only-child) {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  /* First paragraph after header — no extra top gap */
  .post__body :global(p:first-child) {
    margin-top: 0;
  }
</style>
