---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date?: string;
  tags?: string[];
  author?: string;
}

const { title, description, date, tags = [], author } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post__header">
      {date && <p class="meta__date">{date}</p>}
      <h1 class="meta__title">{title}</h1>
      {description && <p class="meta__desc">{description}</p>}
      {(author || tags.length > 0) && (
        <div class="meta__foot">
          {author && <p class="meta__author">{author}</p>}
          {tags.length > 0 && (
            <ul class="meta__tags">
              {tags.map((tag) => <li class="meta__tag">{tag}</li>)}
            </ul>
          )}
        </div>
      )}
    </header>
    <slot />
  </article>
</BaseLayout>

<style>
  .meta__date {
    margin: 0 0 var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    letter-spacing: 0.04em;
  }

  .meta__title {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: -0.025em;
  }

  .meta__desc {
    margin: var(--space-3) 0 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
  }

  .meta__foot {
    margin-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .meta__author {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .meta__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .meta__tag {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid currentColor;
    padding: 2px var(--space-2);
  }

  /* ── Article prose ── */
  .post {
    padding: var(--space-12) var(--space-8);
    max-width: 44rem;
  }

  .post__header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: var(--border-width-1) solid var(--color-border-strong);
  }

  @media (min-width: 1200px) {
    .post {
      padding: var(--space-16) var(--space-12);
    }
  }

  .post :global(h2),
  .post :global(h3),
  .post :global(h4) {
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.025em;
    margin-top: var(--space-12);
    margin-bottom: var(--space-3);
  }

  .post :global(h2) { font-size: var(--font-size-2xl); }
  .post :global(h3) { font-size: var(--font-size-xl); }

  .post :global(p) {
    line-height: var(--line-height-relaxed);
    margin: 0 0 var(--space-6);
  }

  .post :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: var(--space-8) 0;
  }

  .post :global(code) {
    font-size: 0.875em;
    background: var(--color-background-surface);
    padding: 2px 6px;
  }

  .post :global(pre) {
    background: var(--color-background-surface);
    padding: var(--space-6);
    overflow-x: auto;
    margin: var(--space-8) 0;
  }

  .post :global(pre code) {
    background: none;
    padding: 0;
  }

  .post :global(blockquote) {
    margin: var(--space-8) 0;
    padding-left: var(--space-6);
    border-left: 2px solid var(--color-text-secondary);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post :global(ul),
  .post :global(ol) {
    padding-left: var(--space-6);
    margin: 0 0 var(--space-6);
  }

  .post :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--line-height-relaxed);
  }
</style>
