---

---

<figure class="voxel-work" aria-hidden="true">
  <div class="voxel-work__stage"></div>
</figure>

<style>
  .voxel-work {
    --vw-bg: var(--neutral-900);
    --vw-fill: var(--neutral-900);
    --vw-fill-light: var(--neutral-700);
    --vw-stroke: var(--color-background);
    --vw-text: var(--neutral-50);

    position: relative;
    width: 100%;
    height: 100%;
    margin: 0;
    /*background: var(--vw-bg);*/
    overflow: hidden;
  }

  .voxel-work__stage {
    position: absolute;
    inset: 0;
    top: -3rem;
  }

  .voxel-work__stage :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .voxel-work__wordmark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-nature), system-ui, sans-serif;
    font-size: clamp(120px, 22vw, 280px);
    font-weight: var(--font-weight-bold);
    color: var(--vw-text);
    letter-spacing: -0.04em;
    line-height: 1;
    z-index: 10;
    user-select: none;
  }
</style>

<script>
  type VoxelWorkState = {
    bound: boolean;
    cleanup?: () => void;
    initFrameId?: number;
    runId: number;
  };

  type VoxelWorkWindow = Window &
    typeof globalThis & {
      __nopeVoxelWork?: VoxelWorkState;
    };

  const voxelWindow = window as VoxelWorkWindow;
  const voxelState =
    voxelWindow.__nopeVoxelWork ??
    (voxelWindow.__nopeVoxelWork = {
      bound: false,
      runId: 0,
    });

  const canLoadVoxel = () =>
    window.matchMedia("(min-width: 769px)").matches &&
    window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  const clearStage = (section: HTMLElement) => {
    const stage = section.querySelector<HTMLElement>(".voxel-work__stage");
    if (stage) stage.innerHTML = "";
  };

  async function init() {
    const runId = ++voxelState.runId;

    voxelState.cleanup?.();
    voxelState.cleanup = undefined;

    const sections = Array.from(
      document.querySelectorAll<HTMLElement>(".voxel-work"),
    );

    if (!sections.length || !canLoadVoxel()) {
      sections.forEach(clearStage);
      return;
    }

    if (!canLoadVoxel()) return;

    const { Heerich } = await import("heerich");

    if (runId !== voxelState.runId || !canLoadVoxel()) {
      sections.forEach(clearStage);
      return;
    }

    const cleanups: Array<() => void> = [];

    sections.forEach((section) => {
      const stage = section.querySelector<HTMLElement>(".voxel-work__stage");
      if (!stage) return;

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const styles = getComputedStyle(section);
      const token = (name: string, fallback: string) =>
        styles.getPropertyValue(name)?.trim() || fallback;

      const colors = {
        bg: token("--vw-bg", "#080808"),
        fill: token("--vw-fill", "#2a2a32"),
        fillLight: token("--vw-fill-light", "#3d3d48"),
        stroke: token("--vw-stroke", "#4a4a58"),
      };

      const h = new Heerich({
        tile: 42,
        camera: { type: "perspective", position: [6, 8], distance: 14 },
        style: {
          fill: colors.fill,
          stroke: colors.stroke,
          strokeWidth: 0.6,
        },
      });

      function buildScene() {
        h.clear();

        // Main platform base
        h.applyGeometry({
          type: "box",
          position: [0, 0, 0],
          size: [16, 1, 14],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Tall tower left-back
        h.applyGeometry({
          type: "box",
          position: [1, 1, 1],
          size: [3, 8, 3],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Medium block center-left
        h.applyGeometry({
          type: "box",
          position: [5, 1, 2],
          size: [4, 4, 4],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Carve a notch from center block
        h.removeGeometry({
          type: "box",
          position: [6, 1, 3],
          size: [2, 2, 2],
        });

        // Stepped blocks back-right
        h.applyGeometry({
          type: "box",
          position: [10, 1, 1],
          size: [5, 2, 4],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        h.applyGeometry({
          type: "box",
          position: [11, 3, 2],
          size: [3, 2, 2],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Thin tall pillar
        h.applyGeometry({
          type: "box",
          position: [13, 1, 8],
          size: [2, 6, 2],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Low wide block front
        h.applyGeometry({
          type: "box",
          position: [2, 1, 8],
          size: [6, 2, 5],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Small cube accent
        h.applyGeometry({
          type: "box",
          position: [4, 3, 9],
          size: [2, 2, 2],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });

        // Floating block (gap underneath)
        h.applyGeometry({
          type: "box",
          position: [9, 5, 7],
          size: [3, 2, 3],
          style: {
            default: {
              fill: colors.fill,
              stroke: colors.stroke,
              strokeWidth: 0.5,
            },
            top: { fill: colors.fillLight },
          },
        });
      }

      const render = () => {
        stage.innerHTML = h.toSVG({ padding: 40 });
      };

      buildScene();
      render();

      let rafId: number | undefined;

      if (!prefersReducedMotion) {
        const rotationSpeed = 0.00018;
        const radius = 12;
        const camY = 8;

        const animate = (now: number) => {
          const angle = now * rotationSpeed;
          // Slight ellipse so x and y axes move at different rates
          const px = Math.cos(angle * 1.0) * radius;
          const py = Math.sin(angle * 0.7) * radius;
          // Gentle vertical drift on a slower, independent cycle
          const drift = Math.sin(now * 0.00011) * 1.2;
          // Distance breathes very slowly
          const dist = 14 + Math.sin(now * 0.00007) * 0.8;
          h.setCamera({
            type: "perspective",
            position: [px + camY, py + camY + drift],
            distance: dist,
          });
          render();
          rafId = requestAnimationFrame(animate);
        };
        rafId = requestAnimationFrame(animate);
      }

      cleanups.push(() => {
        if (rafId !== undefined) cancelAnimationFrame(rafId);
        stage.innerHTML = "";
      });
    });

    if (runId !== voxelState.runId) {
      cleanups.forEach((cleanup) => cleanup());
      return;
    }

    voxelState.cleanup = () => {
      cleanups.forEach((cleanup) => cleanup());
      voxelState.cleanup = undefined;
    };
  }

  const scheduleInit = () => {
    if (voxelState.initFrameId !== undefined) {
      cancelAnimationFrame(voxelState.initFrameId);
    }

    // Defer one frame so the view-transition animation has committed
    // and the voxel element has real layout dimensions.
    voxelState.initFrameId = requestAnimationFrame(() => {
      voxelState.initFrameId = undefined;
      init();
    });
  };

  const cleanup = () => {
    voxelState.runId += 1;

    if (voxelState.initFrameId !== undefined) {
      cancelAnimationFrame(voxelState.initFrameId);
      voxelState.initFrameId = undefined;
    }

    voxelState.cleanup?.();
    document
      .querySelectorAll<HTMLElement>(".voxel-work")
      .forEach(clearStage);
  };

  if (!voxelState.bound) {
    document.addEventListener("astro:page-load", scheduleInit);
    document.addEventListener("astro:before-swap", cleanup);
    voxelState.bound = true;
  }

  scheduleInit();
</script>
