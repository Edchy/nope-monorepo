---
interface Item {
  href: string;
  label: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<nav class="sourcelist">
  <p class="sourcelist__heading">Sources</p>
  <ul>
    {items.map((item) => (
      <li><a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a></li>
    ))}
  </ul>
</nav>

<style>
  .sourcelist {
    margin-block: 2rem;
    font-size: 0.85em;
    opacity: 0.8;
  }
  .sourcelist__heading {
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
</style>
