---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside class="infobox">
  {title && <p class="infobox__title">{title}</p>}
  <div class="infobox__body"><slot /></div>
</aside>

<style>
  .infobox {
    border-left: 3px solid currentColor;
    padding: 0.75rem 1rem;
    margin-block: 1.5rem;
    opacity: 0.85;
    font-size: 0.9em;
  }
  .infobox__title {
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .infobox__body :global(p) {
    margin: 0;
  }
  .infobox__body :global(p + p) {
    margin-top: 0.4rem;
  }
</style>
